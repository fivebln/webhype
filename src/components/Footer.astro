---
import Logo from './Logo.astro';

const year = new Date().getFullYear();

const linkGroups = [
  {
    heading: 'Angebot',
    links: [
      { label: 'Pakete', href: '/pakete' },
      { label: 'Leistungsumfang', href: '/leistungsumfang' },
      { label: 'Prozess', href: '/prozess' },
      { label: 'Referenzen', href: '/referenzen' },
      { label: 'Kontakt', href: '/kontakt' },
    ],
  },
  {
    heading: 'Branchen',
    links: [
      { label: 'Handwerk', href: '/branchen/handwerk' },
      { label: 'Arztpraxis', href: '/branchen/arztpraxis' },
      { label: 'Kanzlei', href: '/branchen/kanzlei' },
      { label: 'Gastronomie', href: '/blog/gastro-website-speisekarte-reservierung' },
      { label: 'Coaches', href: '/blog/coach-website-ueber-mich-positionierung' },
      { label: 'Beauty & Fitness', href: '/blog/beauty-fitness-website-buchung-provision' },
      { label: 'Einzelhandel', href: '/blog/einzelhandel-onlineshop-oder-schaufenster' },
      { label: 'Finanz & Immobilien', href: '/blog/finanz-immobilien-website-pflichten-leads' },
      { label: 'Fotografen', href: '/blog/fotografen-kreative-portfolio-website' },
    ],
  },
  {
    heading: 'webhype',
    links: [
      { label: 'Über uns', href: '/ueber' },
      { label: 'Magazin', href: '/blog' },
      { label: 'Impressum', href: '/impressum' },
      { label: 'AGB', href: '/agb' },
      { label: 'Datenschutz', href: '/datenschutz' },
    ],
  },
];
---

<footer class="bg-ink-900 text-blue-100">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-12 sm:py-16">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <Logo variant="dark" class="h-9 w-auto" />
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-white/90">
          Professionelle Websites für mittelständische Unternehmen — in 7 Tagen fertig, fester Preis. Service aus Berlin.
        </p>
        <a
          href="/kontakt"
          class="mt-6 inline-flex items-center gap-2 rounded-md bg-blue-500 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-400"
        >
          Gespräch anfragen →
        </a>
      </div>

      {linkGroups.map((group) => (
        <div>
          <h2 class="text-sm font-semibold text-white">
            {group.heading}
          </h2>
          <ul class="mt-4 flex flex-col gap-2.5 text-sm">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="text-white/85 transition hover:text-white">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <hr class="my-10 border-t border-white/10" />

    <div class="flex flex-col items-start justify-between gap-3 text-xs text-white/70 sm:flex-row sm:items-center">
      <p class="flex items-center gap-3">
        <span>© {year} webhype</span>
        <button
          type="button"
          id="wh-cookie-reopen"
          class="underline underline-offset-2 transition hover:text-white"
        >Cookie-Einstellungen</button>
      </p>
      <p class="flex items-center gap-2">
        <span class="inline-flex h-2 w-2 rounded-full bg-success"></span>
        Aus Berlin · Datenschutz-konform · Deutsche Server
      </p>
    </div>
  </div>

  <script is:inline>
    document.getElementById('wh-cookie-reopen')?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('wh:open-cookie-settings'));
    });
  </script>
</footer>
