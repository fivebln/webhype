---
/**
 * PricingTable — two packages (Starter / Business) with a toggle that
 * switches all cards between two pricing models:
 *   - "service":  one-time + monthly care (499+19 / 999+29)
 *   - "handover": one-time only, you get everything (699 / 1.199)
 * = 4 models total. Business model & CI unchanged.
 */
import PaketCard from './PaketCard.astro';

export interface Props {
  id?: string;
}
const { id = 'preise' } = Astro.props;
---

<div id={id}>
  {/* toggle */}
  <div class="flex justify-center" data-reveal>
    <div class="inline-flex rounded-full border border-ink-100 bg-warm-white p-1" role="group" aria-label="Preismodell wählen">
      <button
        type="button"
        class="pricing-toggle-btn rounded-full px-4 py-2 text-sm font-semibold"
        data-mode-btn="service"
        aria-pressed="true"
      >
        Mit Rundum-Service
      </button>
      <button
        type="button"
        class="pricing-toggle-btn rounded-full px-4 py-2 text-sm font-semibold"
        data-mode-btn="handover"
        aria-pressed="false"
      >
        Einmalig &amp; fertig
      </button>
    </div>
  </div>

  {/* helper line */}
  <p class="mt-4 text-center text-sm text-ink-500" data-reveal>
    <span data-mode-text="service"><strong class="text-ink-900">Rundum-Service:</strong> Wir hosten deine Seite, prüfen sie täglich und du änderst selbst — alles aus einer Hand.</span>
    <span data-mode-text="handover" hidden><strong class="text-ink-900">Einmalig:</strong> Du bekommst alles und kümmerst dich danach selbst. Kein Monatsbeitrag.</span>
  </p>

  {/* cards */}
  <div class="mt-10 grid gap-5 lg:grid-cols-2 lg:max-w-4xl lg:mx-auto" data-pricing-mode="service" data-pricing-cards data-reveal-group>
    <PaketCard variant="starter" />
    <PaketCard variant="business" featured />
  </div>

  <p class="mt-8 text-center text-sm text-ink-500" data-reveal>
    Inklusive: Hosting · Sicherheit · täglicher Check · deine eigenen Änderungen — alles aus einer Hand
  </p>
  <p class="mt-3 text-center text-xs text-ink-400" data-reveal>
    Alle Preise verstehen sich netto zzgl. der gesetzlichen Umsatzsteuer.
  </p>
</div>

<script is:inline>
  (() => {
    const btns = document.querySelectorAll('[data-mode-btn]');
    const cards = document.querySelector('[data-pricing-cards]');
    const texts = document.querySelectorAll('[data-mode-text]');
    if (!cards || !btns.length) return;

    const ACTIVE = ['bg-blue-500', 'text-white', 'shadow-xs'];
    const INACTIVE = ['text-ink-500'];

    function setMode(mode) {
      cards.setAttribute('data-pricing-mode', mode);
      btns.forEach((b) => {
        const on = b.getAttribute('data-mode-btn') === mode;
        b.setAttribute('aria-pressed', String(on));
        ACTIVE.forEach((c) => b.classList.toggle(c, on));
        INACTIVE.forEach((c) => b.classList.toggle(c, !on));
      });
      texts.forEach((t) => {
        t.hidden = t.getAttribute('data-mode-text') !== mode;
      });
      // CTA-Links das gewählte Abrechnungsmodell mitgeben
      document.querySelectorAll('.pricing-cta').forEach((w) => {
        const paket = w.getAttribute('data-paket');
        const a = w.querySelector('a');
        if (a && paket) a.setAttribute('href', `/kontakt?paket=${paket}&modell=${mode === 'service' ? 'service' : 'einmalig'}`);
      });
    }

    btns.forEach((b) => b.addEventListener('click', () => setMode(b.getAttribute('data-mode-btn'))));

    // Detail-Aufklapper beider Karten koppeln: ein Klick öffnet/schließt beide (Vergleich ohne Doppelklick)
    const syncDetails = cards.querySelectorAll('details[data-detail-sync]');
    syncDetails.forEach((d) => {
      d.addEventListener('toggle', () => {
        syncDetails.forEach((o) => { if (o !== d && o.open !== d.open) o.open = d.open; });
      });
    });

    setMode('service');
  })();
</script>
