---
/**
 * GaugeMockup — Lighthouse-style circular score ring.
 * Pure SVG, CI colors. Default shows "100" (Lighthouse Performance).
 */
export interface Props {
  score?: number;
  label?: string;
  sublabel?: string;
  class?: string;
}
const { score = 100, label = 'Tempo', sublabel = 'Bestnote', class: className = '' } = Astro.props;

const r = 54;
const circumference = 2 * Math.PI * r;
const dash = (score / 100) * circumference;
---

<div class={`mockup-card p-5 w-[220px] ${className}`}>
  <div class="flex items-center gap-2">
    <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-blue-50 text-blue-500">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
      </svg>
    </span>
    <span class="text-xs font-medium text-ink-500">{label}</span>
  </div>

  <div class="relative mt-3 flex items-center justify-center">
    <svg width="140" height="140" viewBox="0 0 140 140" class="-rotate-90">
      <circle cx="70" cy="70" r={r} fill="none" stroke="var(--color-ink-100)" stroke-width="10" />
      <circle
        cx="70" cy="70" r={r} fill="none"
        stroke="var(--color-blue-500)" stroke-width="10" stroke-linecap="round"
        stroke-dasharray={`${dash} ${circumference}`}
      />
    </svg>
    <div class="absolute inset-0 flex flex-col items-center justify-center">
      <span class="text-4xl font-bold text-ink-900 headline tnum leading-none">{score}</span>
      <span class="mt-1 text-[10px] font-medium uppercase tracking-wider text-ink-300">{sublabel}</span>
    </div>
  </div>
</div>
