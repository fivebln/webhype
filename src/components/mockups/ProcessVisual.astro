---
/**
 * ProcessVisual — one stylised mockup per process step.
 * type: briefing | call | build | preview | golive
 * Pure CSS/SVG, CI colors. Used in both the pinned stage (desktop)
 * and the stacked mobile fallback.
 */
import BriefingMockup from './BriefingMockup.astro';
import BrowserMockup from './BrowserMockup.astro';

export interface Props { type: string; class?: string; }
const { type, class: className = '' } = Astro.props;
---

{type === 'briefing' && (
  <div class={className}><BriefingMockup /></div>
)}

{type === 'call' && (
  <div class={`mockup-card p-5 w-[260px] ${className}`}>
    <div class="flex items-center gap-2">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-blue-50 text-blue-500">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      </span>
      <div>
        <div class="text-sm font-semibold text-ink-900">Dein Termin</div>
        <div class="text-[11px] text-ink-500">Such dir einen aus</div>
      </div>
    </div>
    <div class="mt-4 space-y-2">
      <div class="flex items-center justify-between rounded-md border-2 border-blue-500 bg-blue-50 px-3 py-2 text-xs font-semibold text-blue-600">Di · 09:00 <span>30 Min</span></div>
      <div class="flex items-center justify-between rounded-md border border-ink-100 px-3 py-2 text-xs text-ink-500">Mi · 14:00 <span>30 Min</span></div>
      <div class="flex items-center justify-between rounded-md border border-ink-100 px-3 py-2 text-xs text-ink-500">Do · 11:00 <span>30 Min</span></div>
    </div>
  </div>
)}

{type === 'build' && (
  <div class={`mockup-card overflow-hidden w-[300px] ${className}`}>
    <div class="flex items-center gap-3 border-b border-ink-100 bg-warm-white px-4 py-2.5">
      <div class="browser-dots flex gap-1.5"><span></span><span></span><span></span></div>
      <div class="text-[11px] text-ink-500">Wir bauen deine Seite</div>
    </div>
    <div class="bg-ink-900 p-4 text-[12px] leading-relaxed text-white/90">
      <div class="flex items-center gap-2"><span class="text-success">✓</span> Startseite</div>
      <div class="flex items-center gap-2"><span class="text-success">✓</span> Leistungen</div>
      <div class="flex items-center gap-2"><span class="text-success">✓</span> Kontakt</div>
      <div class="flex items-center gap-2 text-spark"><span>⟳</span> Bilder werden optimiert …</div>
      <div class="mt-2 h-1.5 w-full rounded-full bg-white/10 overflow-hidden">
        <div class="h-full w-[72%] rounded-full bg-blue-500"></div>
      </div>
      <div class="mt-1.5 text-white/60">Tag 4 von 7</div>
    </div>
  </div>
)}

{type === 'preview' && (
  <div class={`w-[320px] ${className}`}><BrowserMockup url="dein-betrieb.de" /></div>
)}

{type === 'golive' && (
  <div class={`mockup-card p-6 w-[260px] text-center ${className}`}>
    <div class="mx-auto inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-500 text-white shadow-glow">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
    </div>
    <div class="mt-4 text-2xl font-bold text-ink-900 headline">Live 🎉</div>
    <div class="mt-1 inline-flex items-center gap-1.5 rounded-full bg-success/10 px-3 py-1 text-xs font-semibold text-success">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-success"></span> dein-betrieb.de
    </div>
    <p class="mt-3 text-[11px] text-ink-500">Blitzschnell · sicher · online</p>
  </div>
)}
