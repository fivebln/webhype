---
/**
 * SevenDayMockup — "7 Tage" delivery card with a week strip.
 * Pure CSS, CI colors.
 */
export interface Props { class?: string; }
const { class: className = '' } = Astro.props;
const days = ['1', '2', '3', '4', '5', '6', '7'];
---

<div class={`mockup-card p-5 w-[230px] ${className}`}>
  <div class="flex items-center justify-between">
    <span class="text-xs font-medium text-ink-500">Lieferung</span>
    <span class="inline-flex items-center gap-1 rounded-full bg-success/10 px-2 py-0.5 text-[10px] font-semibold text-success">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-success"></span> on track
    </span>
  </div>

  <div class="mt-3 flex items-baseline gap-1.5">
    <span class="text-5xl font-bold text-ink-900 headline tnum leading-none">7</span>
    <span class="text-lg font-semibold text-ink-500 headline">Tage</span>
  </div>

  <div class="mt-4 flex justify-between gap-1">
    {days.map((d, i) => (
      <div class:list={[
        'flex h-8 flex-1 items-center justify-center rounded-md text-[11px] font-semibold',
        i === 6 ? 'bg-blue-500 text-white' : 'bg-warm-white text-ink-300 border border-ink-100'
      ]}>
        {i === 6 ? '✓' : d}
      </div>
    ))}
  </div>
  <p class="mt-3 text-[11px] text-ink-300">ab unserem Gespräch</p>
</div>
