---
export interface Props {
  step: number | string;
  title: string;
  description: string;
  meta?: string;
}

const { step, title, description, meta } = Astro.props;
---

<div class="relative rounded-2xl border border-ink-100 bg-white p-6 transition hover:border-blue-200 hover:shadow-sm">
  <div class="flex items-baseline gap-3">
    <span class="font-mono text-xs font-bold uppercase tracking-wider text-spark">
      Schritt {step}
    </span>
    {meta && <span class="font-mono text-[11px] text-ink-300">· {meta}</span>}
  </div>
  <h3 class="mt-3 text-xl font-bold text-ink-900 headline">{title}</h3>
  <p class="mt-3 text-[15px] leading-relaxed text-ink-500">{description}</p>
</div>
