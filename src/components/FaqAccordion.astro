---
export interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;
---

<div class="divide-y divide-ink-100 rounded-2xl border border-ink-100 bg-white">
  {items.map((item, i) => (
    <details class="group" name="faq" open={i === 0}>
      <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-5 text-left transition hover:bg-ink-50/50 [&::-webkit-details-marker]:hidden">
        <h3 class="text-[17px] font-semibold text-ink-900 headline">{item.question}</h3>
        <span
          class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-ink-200 text-ink-500 transition group-open:rotate-45 group-open:border-blue-500 group-open:text-blue-500"
          aria-hidden="true"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"/>
            <line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
        </span>
      </summary>
      <div class="px-6 pb-5 text-[15px] leading-relaxed text-ink-500">
        <p set:html={item.answer.replaceAll('\n', '<br/>')} />
      </div>
    </details>
  ))}
</div>
