---
import faq from '../content/faq.json';
---

<section id="faq" class="bg-surface py-20 md:py-32 scroll-mt-24">
  <div class="container-content">
    <div class="max-w-3xl mb-12 md:mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest text-accent mb-4">
        FAQ
      </p>
      <h2 class="font-sans font-extrabold text-h2-mobile md:text-h2-desktop">
        Häufige Fragen.
      </h2>
    </div>

    <div class="max-w-3xl mx-auto md:mx-0 divide-y divide-border border-y border-border">
      {
        faq.map((item, idx) => (
          <details class="group" name="faq" open={idx === 0}>
            <summary class="flex items-center justify-between gap-6 py-5 md:py-6 cursor-pointer select-none">
              <span class="font-sans font-bold text-lg md:text-xl text-text">
                {item.q}
              </span>
              <span
                aria-hidden="true"
                class="flex-shrink-0 w-9 h-9 rounded-full border border-border flex items-center justify-center text-text transition-transform duration-300 group-open:rotate-45"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round">
                  <line x1="12" y1="5" x2="12" y2="19" />
                  <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
              </span>
            </summary>
            <div class="pb-6 md:pb-7 pr-12 text-text/85 text-base md:text-lg leading-relaxed">
              {item.a}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
