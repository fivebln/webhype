---
export interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'ghost' | 'spark' | 'inverted';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  arrow?: boolean;
  fullWidth?: boolean;
  ariaLabel?: string;
  disabled?: boolean;
  id?: string;
}

const {
  href,
  type = 'button',
  variant = 'primary',
  size = 'md',
  class: className = '',
  arrow = false,
  fullWidth = false,
  ariaLabel,
  disabled = false,
  id,
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-md font-medium transition-all duration-200 ease-[cubic-bezier(0.2,0.7,0.2,1)] focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:outline-offset-2';

const variants: Record<string, string> = {
  primary:
    'bg-blue-500 text-white shadow-xs hover:bg-blue-400 hover:shadow-glow active:bg-blue-600 disabled:bg-ink-100 disabled:text-ink-300 disabled:hover:shadow-none',
  secondary:
    'bg-transparent text-ink-900 border border-ink-200 hover:bg-ink-50 hover:border-ink-300',
  ghost:
    'bg-transparent text-blue-500 hover:bg-blue-50',
  spark:
    'bg-spark text-ink-900 shadow-xs hover:bg-cyan-300 active:bg-cyan-400 font-semibold',
  inverted:
    'bg-white text-ink-900 hover:bg-warm-white shadow-xs',
};

const sizes: Record<string, string> = {
  sm: 'px-3 py-2 text-sm',
  md: 'px-5 py-2.5 text-[15px]',
  lg: 'px-7 py-3.5 text-base',
};

const classes = [
  base,
  variants[variant],
  sizes[size],
  fullWidth ? 'w-full' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

{href ? (
  <a href={href} class={classes} aria-label={ariaLabel} id={id}>
    <slot />
    {arrow && <span aria-hidden="true">→</span>}
  </a>
) : (
  <button type={type} class={classes} aria-label={ariaLabel} disabled={disabled} id={id}>
    <slot />
    {arrow && <span aria-hidden="true">→</span>}
  </button>
)}
