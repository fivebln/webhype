---
---

<section class="relative bg-bg text-text-light overflow-hidden min-h-[80vh] md:min-h-[90vh] flex items-center pt-24 pb-16 md:pt-28 md:pb-24">
  <!-- Dezenter Akzent-Verlauf, kein Stockfoto -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    <div class="absolute -top-32 -left-32 w-[480px] h-[480px] rounded-full opacity-30 blur-3xl" style="background: radial-gradient(circle, #FF5A1F 0%, transparent 60%);"></div>
    <div class="absolute -bottom-40 right-[-10%] w-[600px] h-[600px] rounded-full opacity-15 blur-3xl" style="background: radial-gradient(circle, #FF5A1F 0%, transparent 70%);"></div>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(to right, #F5F2EC 1px, transparent 1px), linear-gradient(to bottom, #F5F2EC 1px, transparent 1px); background-size: 64px 64px;"></div>
  </div>

  <div class="container-content relative">
    <div class="max-w-hero mx-auto text-center md:text-left">
      <h1 class="font-sans font-extrabold text-h1-mobile md:text-h1-desktop tracking-tight text-text-light animate-fade-up">
        Websites für Handwerk.<br />
        <span class="relative inline-block">
          In 7 Tagen live.
          <span aria-hidden="true" class="absolute left-0 -bottom-2 md:-bottom-3 h-1 md:h-1.5 w-full bg-accent origin-left animate-accent-underline"></span>
        </span>
      </h1>

      <p class="mt-8 md:mt-10 text-lg md:text-2xl text-text-light/80 max-w-2xl md:max-w-3xl mx-auto md:mx-0 animate-fade-up" style="animation-delay: 120ms;">
        Kein WordPress. Kein Stress.<br class="hidden sm:inline" />
        Kein versteckter Preis.
      </p>

      <div class="mt-10 md:mt-12 flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center md:justify-start animate-fade-up" style="animation-delay: 240ms;">
        <a href="#demo" class="btn btn-primary" data-cta="hero-primary">
          15 Min Demo buchen <span aria-hidden="true">→</span>
        </a>
        <a href="#pakete" class="btn btn-secondary-dark">
          Pakete ansehen
        </a>
      </div>

      <ul class="mt-12 md:mt-16 flex flex-wrap gap-x-8 gap-y-3 justify-center md:justify-start text-sm font-medium text-text-light/70 animate-fade-up" style="animation-delay: 360ms;">
        <li class="flex items-center gap-2">
          <span aria-hidden="true" class="inline-block w-1.5 h-1.5 rounded-full bg-accent"></span>
          Hosting in Deutschland
        </li>
        <li class="flex items-center gap-2">
          <span aria-hidden="true" class="inline-block w-1.5 h-1.5 rounded-full bg-accent"></span>
          DSGVO-konform
        </li>
        <li class="flex items-center gap-2">
          <span aria-hidden="true" class="inline-block w-1.5 h-1.5 rounded-full bg-accent"></span>
          Monatlich kündbar
        </li>
      </ul>
    </div>
  </div>
</section>
