---
/**
 * CookieBanner · webhype
 *
 * DSGVO-/TTDSG-konformer Consent-Banner. Privacy-first:
 *  - Standardmäßig NUR technisch notwendige Cookies.
 *  - „Ablehnen" (Nur notwendige) ist gleichwertig zu „Akzeptieren" — kein Dark Pattern.
 *  - Speichert die Wahl in `cookie-consent` (12 Monate, SameSite=Lax) — wie in der
 *    Datenschutzerklärung beschrieben.
 *
 * Die Seite lädt aktuell KEIN Tracking. Der Banner ist die Einwilligungs-Grundlage und
 * stellt das Ergebnis als `window.whConsent` + Event `wh:consent` bereit — daran lassen
 * sich künftige Analytics (z. B. Vercel Web Analytics / MS Clarity) consent-gaten.
 */
---

<div
  id="wh-cookie"
  hidden
  role="dialog"
  aria-label="Cookie-Einstellungen"
  style="position:fixed;left:0;right:0;bottom:0;z-index:60;display:flex;justify-content:center;padding:14px;"
>
  <div style="max-width:680px;width:100%;background:#fff;border:1px solid #E0E3EC;border-radius:14px;box-shadow:0 12px 40px rgba(8,14,30,.14);padding:18px 20px;display:flex;flex-wrap:wrap;align-items:center;gap:14px;">
    <p style="flex:1 1 300px;margin:0;font-size:14px;line-height:1.55;color:#4A5168;">
      Wir nutzen technisch notwendige Cookies. Optionale Cookies für <strong>Statistik</strong> (Google&nbsp;Analytics) setzen wir nur mit deiner Einwilligung.
      <a href="/datenschutz" style="color:#0051FD;text-decoration:underline;white-space:nowrap;">Mehr im Datenschutz</a>
    </p>
    <div style="display:flex;gap:10px;flex:0 0 auto;">
      <button type="button" id="wh-cookie-essential" style="appearance:none;cursor:pointer;font:inherit;font-size:14px;font-weight:600;padding:10px 16px;border-radius:9999px;border:1.5px solid #C9CEDB;background:#fff;color:#0A0E1A;">Nur notwendige</button>
      <button type="button" id="wh-cookie-all" style="appearance:none;cursor:pointer;font:inherit;font-size:14px;font-weight:600;padding:10px 18px;border-radius:9999px;border:1.5px solid #0051FD;background:#0051FD;color:#fff;">Alle akzeptieren</button>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const KEY = 'cookie-consent';
    const el = document.getElementById('wh-cookie');
    if (!el) return;
    const read = (n) => {
      const m = document.cookie.split('; ').find((c) => c.indexOf(n + '=') === 0);
      return m ? m.split('=')[1] : null;
    };
    const write = (v) => {
      const d = new Date();
      d.setFullYear(d.getFullYear() + 1);
      document.cookie = KEY + '=' + v + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
    };
    const apply = (v) => {
      window.whConsent = v;
      document.dispatchEvent(new CustomEvent('wh:consent', { detail: v }));
    };
    // Beim Widerruf gesetzte Statistik-/Marketing-Cookies entfernen (GA4/Meta/Ads).
    const clearTracking = () => {
      const parts = location.hostname.split('.');
      const root = parts.length > 1 ? '.' + parts.slice(-2).join('.') : location.hostname;
      const domains = [location.hostname, '.' + location.hostname, root];
      document.cookie.split('; ').forEach((c) => {
        const name = c.split('=')[0];
        if (/^(_ga|_gid|_gat|_fbp|_fbc|_gcl)/.test(name)) {
          document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';
          domains.forEach((d) => {
            document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;domain=' + d;
          });
        }
      });
    };
    const choose = (v) => {
      const prev = read(KEY);
      write(v);
      apply(v);
      el.hidden = true;
      // Downgrade (all → essential): geladene Tags per Reload entfernen + Cookies löschen.
      if (v === 'essential' && prev === 'all') { clearTracking(); location.reload(); }
    };
    const existing = read(KEY);
    if (existing) apply(existing); else el.hidden = false;
    document.getElementById('wh-cookie-all').addEventListener('click', () => choose('all'));
    document.getElementById('wh-cookie-essential').addEventListener('click', () => choose('essential'));
    // Widerruf / erneut öffnen über den Footer-Link „Cookie-Einstellungen".
    document.addEventListener('wh:open-cookie-settings', () => { el.hidden = false; });
  })();
</script>
