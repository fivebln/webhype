---
export interface Props {
  href: string;
  title: string;
  description: string;
  iconType: 'handwerk' | 'arztpraxis' | 'kanzlei';
  ctaLabel: string;
}

const { href, title, description, iconType, ctaLabel } = Astro.props;

// Lucide-style icon paths for each branche
const iconPaths = {
  handwerk: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
  arztpraxis: `<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>`,
  kanzlei: `<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M9 14l2 2 4-4"/>`,
};
---

<a
  href={href}
  class="group block rounded-2xl border border-ink-100 bg-white p-7 transition-all duration-300 hover:border-blue-500 hover:shadow-md focus-visible:outline-2 focus-visible:outline-blue-500"
>
  <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-blue-50 text-blue-500 transition group-hover:bg-blue-500 group-hover:text-white">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[iconType]} />
  </div>
  <h3 class="mt-5 text-xl font-bold text-ink-900 headline">{title}</h3>
  <p class="mt-2 text-[15px] leading-relaxed text-ink-500">{description}</p>
  <p class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-blue-500 transition group-hover:gap-2.5">
    {ctaLabel}
    <span aria-hidden="true">→</span>
  </p>
</a>
