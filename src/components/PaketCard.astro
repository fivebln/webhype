---
import Button from './Button.astro';

export interface Props {
  variant: 'starter' | 'business';
  featured?: boolean;
}

const { variant, featured = false } = Astro.props;

const data = {
  starter: {
    label: 'Starter',
    price: '499 €',
    subtitle: 'Bis zu 5 Unterseiten. Alles drin.',
    features: [
      'Bis zu 5 Unterseiten',
      'Kontaktformular',
      'DSGVO + Impressum',
      'Basis-SEO + Performance-Setup',
      'Lighthouse 100',
    ],
    cta: 'Starter wählen',
    href: '/kontakt?paket=starter',
    buttonVariant: 'inverted' as const,
  },
  business: {
    label: 'Business',
    price: '999 €',
    subtitle: 'Bis zu 10 Unterseiten. Volles Setup.',
    features: [
      'Bis zu 10 Unterseiten',
      'Branchen- / Detailseiten möglich',
      'Volles SEO + AEO-Setup',
      'Mini-CMS optional (Sanity)',
      'CRO-Architektur + Tracking',
    ],
    cta: 'Business wählen',
    href: '/kontakt?paket=business',
    buttonVariant: 'primary' as const,
  },
}[variant];

const cardClasses = featured
  ? 'relative rounded-2xl border-2 border-blue-500 bg-white p-8 shadow-glow transition-all duration-300 hover:shadow-md'
  : 'relative rounded-2xl border border-ink-100 bg-white p-8 transition-all duration-300 hover:border-ink-200 hover:shadow-md';

const buttonStyle = variant === 'starter' ? 'bg-ink-900 text-white hover:bg-ink-700' : '';
---

<article class={cardClasses}>
  {featured && (
    <div class="absolute -top-3 left-6 rounded-full bg-blue-500 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-white shadow-sm">
      Meistgewählt
    </div>
  )}

  <div class="flex items-baseline justify-between">
    <h3 class="text-xs font-semibold uppercase tracking-wider text-blue-500 headline">{data.label}</h3>
    <span class="font-mono text-xs text-ink-500">7 Tage</span>
  </div>

  <div class="mt-4 font-bold text-ink-900 headline tnum" style="font-size:60px;line-height:1;letter-spacing:-0.02em;">
    {data.price}
  </div>
  <p class="mt-2 text-sm text-ink-500">{data.subtitle}</p>

  <ul class="mt-6 space-y-2.5 text-[15px] text-ink-900">
    {data.features.map((feature) => (
      <li class="flex gap-2.5">
        <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-success/10 text-success" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="2 6 5 9 10 3"/>
          </svg>
        </span>
        <span>{feature}</span>
      </li>
    ))}
  </ul>

  <div class="mt-8">
    <Button href={data.href} variant={data.buttonVariant} fullWidth arrow class={buttonStyle}>
      {data.cta}
    </Button>
  </div>
</article>
