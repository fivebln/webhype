---
import Button from './Button.astro';

export interface Props {
  variant: 'starter' | 'business';
  featured?: boolean;
}

const { variant, featured = false } = Astro.props;

const data = {
  starter: {
    label: 'Starter',
    once: '499 €',
    monthly: '19 €',
    handoverOnce: '699 €',
    subtitle: 'Bis zu 5 Seiten. Für den klaren Auftritt.',
    features: [
      'Bis zu 5 Seiten (z. B. Start, Leistungen, Über uns, Kontakt)',
      'Kontaktformular & Telefon-Knopf',
      'Datenschutz & Impressum — rechtssicher',
      'Blitzschnell und fürs Handy gemacht',
    ],
    cta: 'Starter wählen',
    href: '/kontakt?paket=starter&modell=service',
    buttonVariant: 'ink' as const,
  },
  business: {
    label: 'Business',
    once: '999 €',
    monthly: '29 €',
    handoverOnce: '1.199 €',
    subtitle: 'Bis zu 10 Seiten. Für mehr Anfragen.',
    features: [
      'Bis zu 10 Seiten',
      'Eigene Seiten für deine Leistungen',
      'Bei Google gut auffindbar',
      'Du änderst alles selbst — mit Video-Anleitung',
    ],
    cta: 'Business wählen',
    href: '/kontakt?paket=business&modell=service',
    buttonVariant: 'primary' as const,
  },
}[variant];

const cardClasses = featured
  ? 'relative rounded-2xl border-2 border-blue-500 bg-white p-8 shadow-glow transition-all duration-300 hover:shadow-md'
  : 'relative rounded-2xl border border-ink-100 bg-white p-8 transition-all duration-300 hover:border-ink-200 hover:shadow-md';
---

<article class={cardClasses}>
  {featured && (
    <div class="price-service absolute -top-3 left-6 rounded-full bg-blue-500 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-white shadow-sm">
      Meistgewählt
    </div>
  )}

  <div class="flex items-baseline justify-between">
    <h3 class="text-xs font-semibold uppercase tracking-wider text-blue-500 headline">{data.label}</h3>
    <span class="font-mono text-xs text-ink-500">in 7 Tagen fertig</span>
  </div>

  {/* ===== price: SERVICE mode ===== */}
  <div class="price-service">
    <div class="mt-4 flex items-baseline gap-2">
      <span class="font-bold text-ink-900 headline tnum" style="font-size:60px;line-height:1;letter-spacing:-0.02em;">{data.once}</span>
      <span class="text-sm text-ink-500">einmalig</span>
    </div>
    <div class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-blue-50 px-3 py-1.5 text-sm font-semibold text-blue-600">
      + {data.monthly} pro Monat
    </div>
    <p class="mt-2 text-xs text-ink-400">Einmalpreis &amp; Monatsgebühr zzgl. MwSt.</p>
  </div>

  {/* ===== price: HANDOVER mode ===== */}
  <div class="price-handover">
    <div class="mt-4 flex items-baseline gap-2">
      <span class="font-bold text-ink-900 headline tnum" style="font-size:60px;line-height:1;letter-spacing:-0.02em;">{data.handoverOnce}</span>
      <span class="text-sm text-ink-500">einmalig</span>
    </div>
    <div class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-ink-100 px-3 py-1.5 text-sm font-semibold text-ink-700">
      kein Monatsbeitrag
    </div>
    <p class="mt-2 text-xs text-ink-400">Einmalpreis zzgl. MwSt.</p>
  </div>

  <p class="mt-4 text-sm text-ink-500">{data.subtitle}</p>

  <ul class="mt-6 space-y-2.5 text-[15px] text-ink-900">
    {data.features.map((feature) => (
      <li class="flex gap-2.5">
        <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-success/10 text-success" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="2 6 5 9 10 3"/>
          </svg>
        </span>
        <span>{feature}</span>
      </li>
    ))}
  </ul>

  {/* explainer: SERVICE */}
  <div class="price-service mt-6 rounded-xl bg-ink-50 border border-ink-100 p-4">
    <p class="text-xs font-semibold uppercase tracking-wider text-ink-500">Jeden Monat ({data.monthly})</p>
    <p class="mt-2 text-[14px] leading-relaxed text-ink-700">
      Deine Seite ist immer online, wir prüfen sie täglich und halten alles sicher. Texte und Bilder änderst du selbst — wann immer du willst.
    </p>
  </div>

  {/* explainer: HANDOVER */}
  <div class="price-handover mt-6 rounded-xl bg-ink-50 border border-ink-100 p-4">
    <p class="text-xs font-semibold uppercase tracking-wider text-ink-500">Übergabe — fertig</p>
    <p class="mt-2 text-[14px] leading-relaxed text-ink-700">
      Du bekommst die fertige Website und alle Dateien — gehört komplett dir. Du kümmerst dich danach selbst um Technik und Hosting. Kein Monatsbeitrag.
    </p>
  </div>

  <div class="mt-6 pricing-cta" data-paket={variant}>
    <Button href={data.href} variant={data.buttonVariant} fullWidth arrow>
      {data.cta}
    </Button>
  </div>

  {/* ===== Preis-Transparenz: alle Details zum Aufklappen ===== */}
  <details class="group mt-5 border-t border-ink-100 pt-4" data-detail-sync>
    <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-left [&::-webkit-details-marker]:hidden">
      <span class="text-sm font-semibold text-ink-700">Alle Details — was drin ist &amp; was extra kostet</span>
      <span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-ink-200 text-ink-500 transition group-open:rotate-45 group-open:border-blue-500 group-open:text-blue-500" aria-hidden="true">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </span>
    </summary>

    <div class="mt-4 space-y-5 text-[14px] leading-relaxed text-ink-700">
      {/* enthalten */}
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-ink-500">Im Preis enthalten</p>
        <ul class="mt-2 space-y-1.5">
          {[
            'Individuell gestaltet — kein Baukasten, kein Vorlagen-Look',
            `Bis zu ${variant === 'starter' ? '5' : '10'} Seiten`,
            'Fürs Handy optimiert und schnell geladen',
            'Bei Google auffindbar (Grundlagen eingerichtet)',
            'Datenschutz & Impressum rechtssicher eingerichtet',
            'Eine Korrekturrunde inklusive',
            'In 7 Tagen online',
          ].map((t) => (
            <li class="flex gap-2"><span class="mt-px text-success" aria-hidden="true">✓</span><span>{t}</span></li>
          ))}
          <li class="price-service flex gap-2">
            <span class="mt-px text-success" aria-hidden="true">✓</span>
            <span>Jeden Monat ({data.monthly}): Hosting auf deutschen Servern, täglicher Check, Sicherheits-Updates, Backups — und dein Portal, um Texte &amp; Bilder selbst zu ändern.</span>
          </li>
        </ul>
      </div>

      {/* extra kosten */}
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-ink-500">Was extra kostet — ehrlich vorab</p>
        <ul class="mt-2 space-y-1.5">
          <li class="flex gap-2"><span class="mt-px text-ink-400" aria-hidden="true">›</span><span>Änderungen nach der inklusiven Korrekturrunde: <strong class="text-ink-900">95 € netto/Std</strong> — immer vorher abgesprochen.</span></li>
          <li class="flex gap-2"><span class="mt-px text-ink-400" aria-hidden="true">›</span><span>Zusätzliche Seiten oder neue Funktionen: eigener Festpreis, den du vorher kennst.</span></li>
          <li class="flex gap-2"><span class="mt-px text-ink-400" aria-hidden="true">›</span><span>Deine Wunsch-Domain (z. B. .de): rund 15–20 € im Jahr zum Selbstkostenpreis — je nach Verfügbarkeit der Wunschadresse.</span></li>
          <li class="price-handover flex gap-2"><span class="mt-px text-ink-400" aria-hidden="true">›</span><span>Nach der Übergabe kümmerst du dich selbst um Hosting, Technik und Updates.</span></li>
        </ul>
      </div>

      {/* domain & daten */}
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-ink-500">Domain &amp; Daten gehören dir</p>
        <p class="mt-2">Die Domain läuft auf deinen Namen, deine Inhalte gehören dir. Wenn du gehst, bekommst du alles als Export — kein Knebel, keine Geiselhaft.</p>
      </div>

      {/* laufzeit */}
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-ink-500">Laufzeit &amp; Kündigung</p>
        <p class="price-service mt-2">Der Monatsbeitrag ({data.monthly}) läuft 12 Monate, danach monatlich zum Monatsende kündbar. Die Website bleibt in jedem Fall deine — gekündigt wird nur der laufende Service.</p>
        <p class="price-handover mt-2">Kein Monatsbeitrag, keine Laufzeit: einmal zahlen, fertig.</p>
      </div>

      <p class="text-xs text-ink-400">Verbindlich im Detail: siehe <a href="/agb" class="underline hover:text-blue-600">AGB</a> (§7 Änderungen, §9 Laufzeit).</p>
    </div>
  </details>
</article>
