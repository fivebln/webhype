---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import PricingTable from '../components/PricingTable.astro';
import PortalShowcase from '../components/PortalShowcase.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import StatRow from '../components/StatRow.astro';
import PinnedProcess from '../components/PinnedProcess.astro';
import ReviewMarquee from '../components/ReviewMarquee.astro';
import BrowserMockup from '../components/mockups/BrowserMockup.astro';
import GaugeMockup from '../components/mockups/GaugeMockup.astro';
import SevenDayMockup from '../components/mockups/SevenDayMockup.astro';
import { Image } from 'astro:assets';
import refStudioH from '../assets/referenzen/studio-h-next.png';
import refMedau from '../assets/referenzen/medau.png';
import ref9minds from '../assets/referenzen/9minds.png';
import refKropp from '../assets/referenzen/kropp.png';
import { faqSchema, serviceSchema } from '../lib/schema';
import { getGlobal } from '../lib/cms';

const title = 'webhype – Website in 7 Tagen, Festpreis · Service aus Berlin';
const description =
  'Professionelle Websites für mittelständische Unternehmen. Ein kurzes Gespräch, 7 Tage später fertig. Fester Preis, echter Service aus Berlin.';

// ── Inhalte aus dem CMS (Payload-Bereich „Startseite") mit Original-Texten als Fallback ──
const fallbackStart = {
  heroEyebrow: 'Websites für mittelständische Unternehmen · aus Berlin',
  heroTitleLine1: 'Deine Website.',
  heroTitleLine2: 'In 7 Tagen.',
  heroTitleHighlight: 'Fester Preis.',
  heroSubline:
    'Ein kurzes Gespräch von max. 30 Minuten — mehr brauchen wir nicht von dir. Eine Woche später ist deine neue Website fertig und im Internet. Kein Fachchinesisch, keine versteckten Kosten, kein wochenlanges Hin und Her.',
  heroCtaPrimary: 'Preise ansehen',
  heroCtaSecondary: 'So läuft es ab',
  positioningLine: 'Individueller als ein Baukasten. Günstiger als eine Agentur. Schneller als beide.',
  claimTag1: 'Ab Tag 1 einsatzbereit — gebaut, damit Anfragen reinkommen.',
  trustBadges: [{ text: 'In 7 Tagen fertig' }, { text: 'Fester Preis' }, { text: 'Service aus Berlin' }],
  stats: [
    { value: 'max. 30 Min', label: 'kostet dich das Ganze an Zeit' },
    { value: '7 Tage', label: 'und deine Seite ist online' },
    { value: 'Fixpreis', label: 'keine Überraschungen — du kennst ihn vorher' },
  ],
  faq: [
    { question: 'Was kostet eine Website bei webhype?', answer: '499 € oder 999 € einmalig — plus 19 € bzw. 29 € im Monat. Das ist ein fester Preis, den du vorher kennst, ohne böse Überraschung am Ende. Im Monatspreis ist alles drin: Deine Seite ist immer online, wir prüfen sie täglich und halten sie sicher — und du kannst Texte und Bilder selbst ändern. Alle Preise verstehen sich netto zzgl. der gesetzlichen Umsatzsteuer.' },
    { question: 'Wie lange dauert das wirklich?', answer: '7 Tage, nachdem wir miteinander gesprochen haben. Verbindlich, nicht „ungefähr". Das Einzige, was wir von dir brauchen: ein kurzes Gespräch und ein paar Unterlagen (zum Beispiel dein Logo und Stichpunkte zu deinem Betrieb). In den allermeisten Fällen sind wir genau im Plan.' },
    { question: 'Muss ich mich mit Technik auskennen?', answer: 'Nein, überhaupt nicht. Du erzählst uns einmal von deinem Betrieb, den Rest machen wir. Wenn deine Seite fertig ist und du später selbst etwas ändern möchtest — etwa Öffnungszeiten oder ein Foto — zeigen wir dir das in einem kurzen Video. Einfacher als WhatsApp.' },
    { question: 'Seid ihr ein deutsches Unternehmen?', answer: 'Ja. webhype ist ein Service aus Berlin. Du sprichst mit echten Menschen aus Deutschland, deine Daten liegen auf deutschen Servern, und alles ist nach deutschem Datenschutz gemacht. Echte Erreichbarkeit — kein Callcenter, kein Anbieter aus dem Ausland.' },
  ],
};
const start: any = await getGlobal('web-start', fallbackStart);
const stats = start.stats ?? fallbackStart.stats;
const faqItems = (start.faq ?? fallbackStart.faq).map((f: any) => ({ question: f.question, answer: f.answer }));
const trustBadges = start.trustBadges ?? fallbackStart.trustBadges;

const testimonials = [
  {
    quote: 'Für so eine Seite hätte ich bei einer Agentur locker fünf- bis zehntausend Euro gelassen. Bei webhype war es ein halbstündiges Telefonat, den Rest haben die übernommen.',
    name: 'Maximilian Hauenstein',
    project: 'Studio H.',
    href: '/referenzen/studio-h',
    domain: 'studio-h.web-hype.de',
    initials: 'MH',
    image: refStudioH,
  },
  {
    quote: 'Das Zins-Radar schickt jede Woche automatisch die aktuellen Bauzinsen an meine Kontakte. So bleibe ich präsent, ohne ständig hinterherzutelefonieren.',
    name: 'Alexander Medau',
    project: 'Immobilienfinanzierung',
    href: '/referenzen/alexander-medau',
    domain: 'alexander-medau.de',
    initials: 'AM',
    image: refMedau,
  },
  {
    quote: 'Ich wollte was Eigenes, aber keine Agentur bezahlen, die Monate braucht. Nach einem halbstündigen Gespräch stand eine Seite, die wirklich nach mir klingt.',
    name: 'Paul Adloff',
    project: '9Minds',
    href: '/referenzen/9minds',
    domain: '9minds.web-hype.de',
    initials: 'PA',
    image: ref9minds,
  },
  {
    quote: 'Ich wollte kein Verkaufsprospekt, sondern etwas, das ehrlich rechnet. Jetzt kommen die Leute zu mir, statt dass ich hinterherlaufe.',
    name: 'Felix Kropp',
    project: 'Kinderfrühstart-Rente',
    href: '/referenzen/kinderfruehstart-rente',
    domain: 'kropp.web-hype.de',
    initials: 'FK',
    image: refKropp,
  },
];

const jsonLd = [
  serviceSchema({ name: 'webhype Starter', description: 'Professionelle Website mit bis zu 5 Seiten, in 7 Tagen fertig, fester Preis, Service aus Berlin', url: '/pakete', price: 499, pages: '5', deliveryDays: 7 }),
  serviceSchema({ name: 'webhype Business', description: 'Professionelle Website mit bis zu 10 Seiten, in 7 Tagen fertig, bei Google auffindbar, Service aus Berlin', url: '/pakete', price: 999, pages: '10', deliveryDays: 7 }),
  faqSchema(faqItems),
];
---

<BaseLayout
  title={title}
  description={description}
  ogTitle="Deine Website. In 7 Tagen. Fester Preis."
  ogDescription="Professionelle Websites für mittelständische Unternehmen. Ein kurzes Gespräch, eine Woche später fertig. Service aus Berlin."
  ogImage="/og/index.png"
  jsonLd={jsonLd}
>
  {/* ============ HERO ============ */}
  <section class="bg-warm-white pt-9 sm:pt-12 pb-9 sm:pb-12 overflow-hidden">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div data-reveal>
          <p class="eyebrow">{start.heroEyebrow}</p>
          <h1 class="display-xl mt-5 text-ink-900">
            {start.heroTitleLine1}<br />{start.heroTitleLine2}<br /><span class="text-blue-500">{start.heroTitleHighlight}</span>
          </h1>
          {start.positioningLine && (
            <p class="mt-5 max-w-xl text-lg sm:text-xl font-bold leading-snug text-ink-900">{start.positioningLine}</p>
          )}
          <p class="mt-5 max-w-xl text-lg leading-relaxed text-ink-500">
            {start.heroSubline}
          </p>
          <div class="mt-9 flex flex-wrap gap-3">
            <Button href="/pakete" variant="primary" size="lg" arrow>{start.heroCtaPrimary}</Button>
            <Button href="/prozess" variant="secondary" size="lg">{start.heroCtaSecondary}</Button>
          </div>
          <ul class="mt-9 flex flex-wrap items-center gap-x-6 gap-y-2 text-[13px] text-ink-500">
            {trustBadges.map((b: any) => (
              <li class="flex items-center gap-1.5"><span class="inline-flex h-4 w-4 items-center justify-center rounded-full bg-success/15 text-success"><svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>{b.text}</li>
            ))}
          </ul>
        </div>

        <div class="relative mx-auto w-full max-w-md lg:max-w-none" data-reveal>
          <div class="float-b"><BrowserMockup /></div>
          <div class="absolute -top-8 -right-2 sm:-right-6 float-a hidden sm:block"><GaugeMockup /></div>
          <div class="absolute -bottom-10 -left-2 sm:-left-8 float-c hidden sm:block"><SevenDayMockup /></div>
        </div>
      </div>
    </div>

    {/* Social-Proof — Vertrauenszeile + durchlaufendes Band.
        ⚠️ PLATZHALTER: „Über 500 Kunden" vor Live durch echte Zahl ersetzen. */}
    <div class="mt-10 sm:mt-14">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="flex items-center gap-3" data-reveal>
          <div class="flex -space-x-2.5" aria-hidden="true">
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full ring-2 ring-warm-white bg-blue-100 text-[10px] font-bold text-blue-700">FK</span>
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full ring-2 ring-warm-white bg-ink-100 text-[10px] font-bold text-ink-700">MH</span>
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full ring-2 ring-warm-white bg-blue-500 text-[10px] font-bold text-white">SM</span>
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full ring-2 ring-warm-white bg-blue-100 text-[10px] font-bold text-blue-700">TR</span>
          </div>
          <p class="text-sm text-ink-500">
            <span class="text-warning" aria-hidden="true">★★★★★</span>
            <span class="ml-1"><strong class="font-semibold text-ink-900">Über 500 Kunden</strong> vertrauen uns bereits</span>
          </p>
        </div>
      </div>
      <div class="mt-5"><ReviewMarquee /></div>
    </div>
  </section>

  {/* ============ SCHMERZ (Problem · Agitate) ============ */}
  <Section variant="white" size="lg">
    <div class="max-w-3xl" data-reveal>
      <p class="eyebrow">Mal ehrlich</p>
      <h2 class="display-lg mt-3 text-ink-900">
        Du weißt seit Langem, dass du eine Website brauchst. Aber irgendwas kommt immer dazwischen.
      </h2>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" data-reveal-group>
      {[
        { t: '„Keine Zeit."', d: 'Betrieb läuft, Telefon klingelt — abends ist die Luft raus.' },
        { t: '„Kein Nerv für den Aufwand."', d: 'Texte, Bilder, alles dreimal erklären — der Gedanke nervt.' },
        { t: '„Schon schlecht erlebt."', d: 'Endlose Termine, Fachchinesisch, am Ende die doppelte Rechnung.' },
        { t: '„Keiner nennt den Preis."', d: 'Mal 2.000 €, mal 10.000 €, mal „kommt drauf an".' },
      ].map((p) => (
        <div class="rounded-2xl border border-ink-100 bg-warm-white p-5">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-error/10 text-error" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </span>
          <h3 class="mt-3 text-base font-bold text-ink-900 headline">{p.t}</h3>
          <p class="mt-1.5 text-[14px] leading-snug text-ink-500">{p.d}</p>
        </div>
      ))}
    </div>

    <div class="mt-6 rounded-2xl bg-ink-900 p-6 text-center" data-reveal>
      <p class="text-lg sm:text-xl leading-relaxed text-white">
        Und während du es aufschiebst, googeln deine Kunden dich — und finden <span class="text-spark">nichts</span>. Oder eine Seite von 2012.
        <br class="hidden sm:block" />Beides kostet dich Aufträge. <span class="font-semibold">Tag für Tag.</span>
      </p>
    </div>
  </Section>

  {/* ============ LÖSUNG (kompakt) ============ */}
  <section class="bg-warm-white py-8 sm:py-10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="rounded-3xl bg-ink-50 px-6 py-8 sm:px-10 sm:py-10" data-reveal>
        <p class="eyebrow">Die Lösung</p>
        <h2 class="display-lg mt-3 text-ink-900">Schnell fertig. Fester Preis. Echte Menschen aus Berlin.</h2>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-500">
          Genau die Gründe, warum du es bisher aufgeschoben hast, nehmen wir dir ab.
        </p>
        {start.claimTag1 && <p class="mt-4 text-base sm:text-lg font-bold text-blue-500">{start.claimTag1}</p>}
        <div class="mt-8">
          <StatRow stats={stats} />
        </div>
      </div>
    </div>
  </section>

  {/* ============ PREISE (direkt nach der Lösung) ============ */}
  <Section variant="white" size="lg" id="preise">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <p class="eyebrow justify-center">Einfache Preise</p>
      <h2 class="display-lg mt-3 text-ink-900">Du weißt vorher, was es kostet.</h2>
      <p class="mt-5 text-lg leading-relaxed text-ink-500">Such dir aus, wie du es haben willst: Wir kümmern uns dauerhaft um alles (kleiner Monatsbeitrag) — oder du bekommst die Website einmalig und machst dann selbst weiter.</p>
    </div>

    <div class="mt-12">
      <PricingTable />
    </div>

    <div class="mt-10 rounded-2xl bg-ink-50 border border-ink-100 p-6 sm:p-7 text-center max-w-3xl mx-auto" data-reveal>
      <h3 class="text-lg font-bold text-ink-900 headline">Du weißt nicht, was du brauchst?</h3>
      <p class="mt-2 text-[15px] text-ink-500">Kein Problem. Beantworte ein paar einfache Fragen — wir schlagen dir das passende Paket vor.</p>
      <div class="mt-5">
        <Button href="/preis-finden" variant="primary" arrow>In 2 Minuten dein Paket finden</Button>
      </div>
    </div>
  </Section>

  {/* ============ ⭐ DU GIBST DEIN GO (Prozess, gepinnt) ============ */}
  <PinnedProcess />

  {/* ============ IMMER DABEI (kompakt) ============ */}
  <Section variant="white" size="lg">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <p class="eyebrow justify-center">Immer dabei</p>
      <h2 class="display-lg mt-3 text-ink-900">Vier Dinge, die immer drin sind.</h2>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" data-reveal-group>
      <div class="rounded-2xl bg-ink-50 border border-ink-100 p-6">
        <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-500" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9z"/></svg>
        </span>
        <h3 class="mt-4 text-lg font-bold text-ink-900 headline">Blitzschnell</h3>
        <p class="mt-1.5 text-[14px] leading-snug text-ink-500">Deine Seite lädt sofort — auch auf älteren Handys.</p>
      </div>

      <div class="rounded-2xl bg-ink-50 border border-ink-100 p-6">
        <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-500" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        </span>
        <h3 class="mt-4 text-lg font-bold text-ink-900 headline">Rechtlich sicher</h3>
        <p class="mt-1.5 text-[14px] leading-snug text-ink-500">Datenschutz, Impressum, Cookie-Hinweis — alles korrekt, keine Abmahnung.</p>
      </div>

      <div class="rounded-2xl bg-ink-50 border border-ink-100 p-6">
        <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-500" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </span>
        <h3 class="mt-4 text-lg font-bold text-ink-900 headline">Bei Google gefunden</h3>
        <p class="mt-1.5 text-[14px] leading-snug text-ink-500">Eingerichtet, damit Kunden dich finden, wenn sie suchen.</p>
      </div>

      <div class="rounded-2xl bg-ink-50 border border-ink-100 p-6">
        <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-500" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </span>
        <h3 class="mt-4 text-lg font-bold text-ink-900 headline">Mehr Anrufe</h3>
        <p class="mt-1.5 text-[14px] leading-snug text-ink-500">Telefonnummer und Kontakt-Knopf immer gut sichtbar.</p>
      </div>
    </div>
  </Section>

  {/* ============ PORTAL-SHOWCASE ============ */}
  <PortalShowcase />

  {/* ============ REFERENZEN ============ */}
  <section class="bg-ink-50 py-10 sm:py-14 border-t border-ink-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div data-reveal>
        <p class="eyebrow">Kundenstimmen</p>
        <h2 class="display-lg mt-3 text-ink-900">Schau dir an, was wir gebaut haben.</h2>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-500">
          Echte Seiten, echte Kunden. Das sagen Unternehmer und Unternehmerinnen, für die wir bereits Websites gebaut haben.
        </p>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-2" data-reveal-group>
        {testimonials.map((t) => (
          <figure class="flex flex-col overflow-hidden rounded-3xl border border-ink-100 bg-white shadow-sm">
            {/* Live-Vorschau im Browser-Rahmen — echte, von webhype gebaute Seite */}
            <a href={t.href} class="group block" aria-label={`Case Study zu ${t.project} ansehen`}>
              <div class="flex items-center gap-2 border-b border-ink-100 bg-ink-50 px-4 py-2.5">
                <span class="flex gap-1.5" aria-hidden="true">
                  <span class="h-2.5 w-2.5 rounded-full bg-ink-200"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-ink-200"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-ink-200"></span>
                </span>
                <span class="ml-2 flex-1 truncate rounded-md border border-ink-100 bg-white px-3 py-1 text-[11px] text-ink-400">{t.domain}</span>
              </div>
              <div class="aspect-[16/10] overflow-hidden bg-ink-50">
                <Image src={t.image} alt={`Von webhype gebaute Website für ${t.name}`} width={1280} height={800} format="webp" quality={72} class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]" />
              </div>
            </a>

            {/* Bewertung + Person */}
            <div class="flex flex-col p-7 sm:p-8">
              <div class="flex gap-1 text-warning" aria-hidden="true">
                {[0,1,2,3,4].map(() => (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                ))}
              </div>
              <blockquote class="mt-4 text-lg leading-relaxed text-ink-900">„{t.quote}"</blockquote>
              <figcaption class="mt-6 flex items-center gap-3">
                <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-blue-500 text-sm font-semibold text-white">{t.initials}</span>
                <div>
                  <div class="font-semibold text-ink-900">{t.name}</div>
                  <a href={t.href} class="text-sm text-blue-500 hover:text-blue-600">Case Study ansehen →</a>
                </div>
              </figcaption>
            </div>
          </figure>
        ))}
      </div>
      <div class="mt-8" data-reveal>
        <a href="/referenzen" class="inline-flex items-center gap-1.5 text-base font-semibold text-blue-500 hover:text-blue-600">Alle Referenzen ansehen →</a>
      </div>
    </div>
  </section>

  {/* ============ VERTRAUEN ============ */}
  <Section variant="white" size="lg">
    <div data-reveal>
      <p class="eyebrow">Darauf kannst du dich verlassen</p>
      <h2 class="display-lg mt-3 text-ink-900">Du musst uns nicht blind vertrauen.</h2>
    </div>
    <div class="mt-12 grid gap-5 md:grid-cols-3" data-reveal-group>
      <div class="rounded-2xl border border-ink-100 bg-warm-white p-7">
        <div class="font-mono text-xs font-bold uppercase tracking-wider text-blue-500">01</div>
        <h3 class="mt-3 text-xl font-bold text-ink-900 headline">Schnell? Test es selbst.</h3>
        <p class="mt-3 text-[15px] leading-relaxed text-ink-500">Im Tempo-Test von <a href="https://pagespeed.web.dev/analysis?url=https://web-hype.de" rel="noopener noreferrer" target="_blank" class="underline text-blue-500 hover:text-blue-600">Google PageSpeed</a> erreicht diese Seite 100/100 Performance im Desktop-Test. Deine Seite bauen wir mit derselben Sorgfalt aufs Tempo — schlanker Code, optimierte Bilder, schnelles Hosting.</p>
      </div>
      <div class="rounded-2xl border border-blue-200 bg-blue-50 p-7">
        <div class="font-mono text-xs font-bold uppercase tracking-wider text-blue-500">02</div>
        <h3 class="mt-3 text-xl font-bold text-ink-900 headline">Wir bleiben an deiner Seite.</h3>
        <p class="mt-3 text-[15px] leading-relaxed text-ink-500">Beim Rundum-Service kümmern wir uns nach dem Start dauerhaft weiter: Hosting, Sicherheit und täglicher Check laufen automatisch — du musst nichts tun. Bei der einmaligen Übergabe machst du danach selbst weiter.</p>
      </div>
      <div class="rounded-2xl border border-ink-100 bg-warm-white p-7">
        <div class="font-mono text-xs font-bold uppercase tracking-wider text-blue-500">03</div>
        <h3 class="mt-3 text-xl font-bold text-ink-900 headline">Echte Menschen aus Berlin.</h3>
        <p class="mt-3 text-[15px] leading-relaxed text-ink-500">Kein Callcenter, kein Anbieter aus dem Ausland. Du sprichst mit echten Menschen aus Deutschland — und erreichst uns auch wirklich.</p>
      </div>
    </div>
  </Section>

  {/* ============ FAQ ============ */}
  <section class="bg-ink-50 py-10 sm:py-14 border-t border-ink-100" id="faq">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div data-reveal>
        <p class="eyebrow">Häufige Fragen</p>
        <h2 class="display-lg mt-3 text-ink-900">Die kurzen Antworten.</h2>
      </div>
      <div class="mt-8 max-w-3xl" data-reveal>
        <FaqAccordion items={faqItems} />
      </div>
    </div>
  </section>

  {/* ============ FINAL CTA (dark) ============ */}
  <Section variant="ink" size="xl">
    <div data-reveal>
      <p class="eyebrow is-spark is-light">Lass uns reden</p>
      <h2 class="display-lg mt-3 text-white">Bereit für deine neue Website?</h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-blue-100">Ein kurzes Gespräch. Fester Preis. Nächste Woche bist du online. Service aus Berlin.</p>
      <div class="mt-9 flex flex-wrap gap-3">
        <Button href="/kontakt" variant="primary" size="lg" arrow>Gespräch anfragen</Button>
        <Button href="/pakete" variant="inverted" size="lg">Preise ansehen</Button>
      </div>
    </div>
  </Section>
</BaseLayout>
