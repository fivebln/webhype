---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';
import { breadcrumbSchema, serviceSchema } from '../../lib/schema';

const title = 'Website für Handwerker – in 7 Tagen, fester Preis · webhype';
const description =
  'Moderne Website für deinen Handwerksbetrieb. Gut auf dem Handy, Telefonnummer immer sichtbar, echte Bilder. In 7 Tagen fertig, fester Preis. Service aus Berlin.';

const pains = [
  { title: '„Meine Website sieht aus wie von 2014."', body: 'Junge Kunden googeln zuerst. Sieht deine Seite alt aus, gehen sie zur Konkurrenz — auch wenn deine Arbeit besser ist.' },
  { title: '„Ich komm an meine eigene Seite nicht mehr ran."', body: 'Der alte Webmensch ist nicht mehr erreichbar, der Vertrag läuft weiter, ändern kann niemand etwas.' },
  { title: '„Meine Nummer findet keiner."', body: 'Wenn Kunden anrufen sollen, muss die Telefonnummer überall gut sichtbar sein — und auf dem Handy mit einem Tipp wählbar.' },
];

const points = [
  { num: '01', title: 'Telefonnummer immer sichtbar', body: 'Deine Nummer steht oben, im Text und unten — auf dem Handy mit einem Tipp wählbar. Damit aus Besuchern Anrufe werden.' },
  { num: '02', title: 'Gut auf dem Handy', body: 'Die meisten schauen vom Handy — auf der Baustelle, im Auto, abends auf der Couch. Wir bauen zuerst fürs Handy.' },
  { num: '03', title: 'Echte Bilder von dir', body: 'Hast du eigene Fotos (Werkstatt, Team, fertige Arbeiten)? Perfekt. Wenn nicht, suchen wir echte Bilder — keine gestellten Anzug-Männer.' },
  { num: '04', title: 'Du brauchst kein Technik-Wissen', body: 'Du erzählst uns einmal von deinem Betrieb, den Rest machen wir. Später Öffnungszeiten oder ein Foto ändern? Zeigen wir dir in einem kurzen Video.' },
];

const jsonLd = [
  breadcrumbSchema([
    { name: 'Startseite', url: '/' },
    { name: 'Branchen', url: '/branchen/handwerk' },
    { name: 'Handwerk', url: '/branchen/handwerk' },
  ]),
  serviceSchema({ name: 'Website für Handwerksbetriebe', description: 'Mobile-first Websites mit gut sichtbarer Telefonnummer, in 7 Tagen fertig', url: '/branchen/handwerk', price: 499, pages: '5–10', deliveryDays: 7 }),
];
---

<BaseLayout title={title} description={description} ogTitle="Website für Handwerker · 7 Tage · fester Preis" ogDescription="Gut auf dem Handy, Telefonnummer immer sichtbar, echte Bilder. Service aus Berlin." ogImage="/og/branche-handwerk.png" jsonLd={jsonLd}>
  {/* HERO */}
  <Section variant="warm-white" size="xl">
    <div class="max-w-3xl" data-reveal>
      <p class="eyebrow">Für Handwerksbetriebe</p>
      <h1 class="display-xl mt-3 text-ink-900">Die Website, die deine Kunden anruft.</h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-500">
        Für Sanitär, Heizung, Elektrik, Maler, Dachdecker, Schreiner — gut auf dem Handy, mit gut sichtbarer Telefonnummer und echten Bildern aus deinem Betrieb. In 7 Tagen fertig, fester Preis.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <Button href="/kontakt?branche=handwerk" variant="primary" size="lg" arrow>Termin sichern</Button>
        <Button href="/pakete" variant="secondary" size="lg">Preise ansehen</Button>
      </div>
    </div>
  </Section>

  {/* PAINS */}
  <Section variant="white" size="lg">
    <div data-reveal><p class="eyebrow">Kennst du das?</p><h2 class="display-lg mt-3 text-ink-900">Drei Sätze, die wir oft hören.</h2></div>
    <div class="mt-12 grid gap-5 md:grid-cols-3" data-reveal-group>
      {pains.map((p) => (
        <div class="rounded-2xl border border-ink-100 bg-warm-white p-7">
          <h3 class="text-lg font-bold text-ink-900 italic headline">{p.title}</h3>
          <p class="mt-4 text-[15px] leading-relaxed text-ink-500">{p.body}</p>
        </div>
      ))}
    </div>
  </Section>

  {/* POINTS */}
  <Section variant="warm-white" size="lg">
    <div data-reveal><p class="eyebrow">So bauen wir für Handwerk</p><h2 class="display-lg mt-3 text-ink-900">Vier Dinge, die wir immer machen.</h2></div>
    <div class="mt-12 grid gap-5 md:grid-cols-2" data-reveal-group>
      {points.map((d) => (
        <div class="rounded-2xl border border-ink-100 bg-white p-7">
          <div class="font-mono text-xs font-bold uppercase tracking-wider text-blue-500">{d.num}</div>
          <h3 class="mt-3 text-xl font-bold text-ink-900 headline">{d.title}</h3>
          <p class="mt-3 text-[15px] leading-relaxed text-ink-500">{d.body}</p>
        </div>
      ))}
    </div>
  </Section>

  {/* FINAL CTA */}
  <Section variant="ink" size="xl">
    <div data-reveal>
      <h2 class="display-lg text-white">Bereit für eine Website, die anruft?</h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-blue-100">Ein kurzes Gespräch von max. 30 Minuten. Wir verstehen Handwerk.</p>
      <div class="mt-9 flex flex-wrap gap-3">
        <Button href="/kontakt?branche=handwerk" variant="primary" size="lg" arrow>Termin sichern</Button>
        <Button href="/preis-finden" variant="inverted" size="lg">Paket finden</Button>
      </div>
    </div>
  </Section>
</BaseLayout>
