---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';
import { breadcrumbSchema, serviceSchema } from '../../lib/schema';

const title = 'Website für Arzt- & Zahnarztpraxen – datenschutz-konform · webhype';
const description =
  'Moderne Website für deine Praxis. Datenschutz-konform, mit echten Team-Fotos und verständlichen Behandlungen. In 7 Tagen fertig. Service aus Berlin.';

const pains = [
  { title: '„Ist mein Datenschutz überhaupt korrekt?"', body: 'Kollegen wurden abgemahnt. Cookie-Hinweis veraltet, Datenschutz unklar. Jede falsche Zeile kann teuer werden.' },
  { title: '„Wir suchen Personal — aber die Seite wirkt von gestern."', body: 'Fachkräfte schauen sich Praxen online an, bevor sie sich bewerben. Eine alte Seite schreckt ab.' },
  { title: '„Die Fotos wirken nicht wie wir."', body: 'Patienten kommen, weil sie Vertrauen haben. Vertrauen entsteht durch echte Bilder echter Menschen — nicht durch gestellte Foto-Archiv-Bilder.' },
];

const points = [
  { num: '01', title: 'Datenschutz richtig gemacht', body: 'Cookie-Hinweis, Datenschutzerklärung und Impressum — sauber nach deutschem Recht, damit du keine Abmahnung bekommst. (Einen externen Datenschutzbeauftragten empfehlen wir trotzdem.)' },
  { num: '02', title: 'Echte Team-Fotos', body: 'Wir helfen beim Fototermin oder nutzen deine vorhandenen Bilder — damit deine Praxis so wirkt, wie sie ist.' },
  { num: '03', title: 'Behandlungen verständlich', body: 'Patienten suchen nach Beschwerden, nicht nach Fachbegriffen. Wir erklären deine Behandlungen so, dass jeder sie versteht — und du kontrollierst jeden Satz.' },
  { num: '04', title: 'Karriere-Seite, die überzeugt', body: 'Wenn du Personal suchst, bauen wir eine Seite, die Bewerber anspricht — mit echten Argumenten, nicht mit Floskeln.' },
];

const jsonLd = [
  breadcrumbSchema([
    { name: 'Startseite', url: '/' },
    { name: 'Branchen', url: '/branchen/arztpraxis' },
    { name: 'Arztpraxis', url: '/branchen/arztpraxis' },
  ]),
  serviceSchema({ name: 'Website für Arzt- und Zahnarztpraxen', description: 'Datenschutz-konforme Websites mit echten Team-Fotos, in 7 Tagen fertig', url: '/branchen/arztpraxis', price: 499, pages: '5–10', deliveryDays: 7 }),
];
---

<BaseLayout title={title} description={description} ogTitle="Praxis-Website · datenschutz-konform · 7 Tage" ogDescription="Vertrauenswürdig wie deine Praxis. Echte Team-Fotos statt Foto-Archiv. Service aus Berlin." ogImage="/og/branche-arztpraxis.png" jsonLd={jsonLd}>
  {/* HERO */}
  <Section variant="warm-white" size="xl">
    <div class="max-w-3xl" data-reveal>
      <p class="eyebrow">Für Arzt- & Zahnarztpraxen</p>
      <h1 class="display-xl mt-3 text-ink-900">Deine Praxis online — seriös und sicher.</h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-500">
        Für Praxen, die vertrauenswürdig wirken müssen, weil sie es sind. Mit echten Team-Fotos, verständlichen Behandlungen und korrektem Datenschutz. In 7 Tagen fertig, fester Preis.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <Button href="/kontakt?branche=arztpraxis" variant="primary" size="lg" arrow>Termin sichern</Button>
        <Button href="/pakete" variant="secondary" size="lg">Preise ansehen</Button>
      </div>
    </div>
  </Section>

  {/* PAINS */}
  <Section variant="white" size="lg">
    <div data-reveal><p class="eyebrow">Kennst du das?</p><h2 class="display-lg mt-3 text-ink-900">Drei Bedenken, die wir oft hören.</h2></div>
    <div class="mt-12 grid gap-5 md:grid-cols-3" data-reveal-group>
      {pains.map((p) => (
        <div class="rounded-2xl border border-ink-100 bg-warm-white p-7">
          <h3 class="text-lg font-bold text-ink-900 italic headline">{p.title}</h3>
          <p class="mt-4 text-[15px] leading-relaxed text-ink-500">{p.body}</p>
        </div>
      ))}
    </div>
  </Section>

  {/* POINTS */}
  <Section variant="warm-white" size="lg">
    <div data-reveal><p class="eyebrow">So bauen wir für Praxen</p><h2 class="display-lg mt-3 text-ink-900">Vier Dinge, die wir immer machen.</h2></div>
    <div class="mt-12 grid gap-5 md:grid-cols-2" data-reveal-group>
      {points.map((d) => (
        <div class="rounded-2xl border border-ink-100 bg-white p-7">
          <div class="font-mono text-xs font-bold uppercase tracking-wider text-blue-500">{d.num}</div>
          <h3 class="mt-3 text-xl font-bold text-ink-900 headline">{d.title}</h3>
          <p class="mt-3 text-[15px] leading-relaxed text-ink-500">{d.body}</p>
        </div>
      ))}
    </div>
  </Section>

  {/* FINAL CTA */}
  <Section variant="ink" size="xl">
    <div data-reveal>
      <h2 class="display-lg text-white">Bereit für eine Praxis-Website, die wirkt wie deine Praxis?</h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-blue-100">Ein kurzes Gespräch von max. 30 Minuten.</p>
      <div class="mt-9 flex flex-wrap gap-3">
        <Button href="/kontakt?branche=arztpraxis" variant="primary" size="lg" arrow>Termin sichern</Button>
        <Button href="/preis-finden" variant="inverted" size="lg">Paket finden</Button>
      </div>
    </div>
  </Section>
</BaseLayout>
