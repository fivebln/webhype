---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';
import { breadcrumbSchema, serviceSchema } from '../../lib/schema';

const title = 'Kanzlei-Website mit Lighthouse 100 · webhype';
const description =
  'Conversion-starke Websites für Kanzleien, Steuerberatungen und Beratungen. Lighthouse 100, AEO-optimiert, mit Tracking. 7 Tage Lieferung.';

const pains = [
  { title: '„Meine Website sieht aus wie alle anderen."', body: 'Aktenfoto. Bibliotheks-Hintergrund. „Vertrauen seit 1987". Drei lateinische Phrasen. Wenn du gegen alteingesessene Kanzleien um den nächsten Mandanten kämpfst, fällst du so nicht auf.' },
  { title: '„Ich weiß nicht, was funktioniert."', body: 'Kein Analytics, keine Conversion-Daten, keine Hypothese. Du gibst Geld für Empfehlungs-Marketing aus, aber weißt nicht, ob die Website Leads konvertiert oder nur Visitenkarte ist.' },
  { title: '„Ich will mitsteuern."', body: 'Du willst nicht „dem Designer vertrauen". Du willst KPIs, Daten, transparente Entscheidungen. Klassische Agenturen geben dir das nicht. Wir schon.' },
];

const differentiators = [
  { num: '01', title: 'Lighthouse 100 als Pflicht-Beweis', body: 'Wir liefern nicht „gute Performance". Wir liefern Lighthouse 100 in Performance + SEO, ≥95 in Accessibility + Best Practices. Mobil und Desktop. Du siehst den Score live auf deiner eigenen Domain — kein Screenshot, keine Ausreden.' },
  { num: '02', title: 'AEO/GEO-Setup für KI-Suchen', body: '2026 googeln Menschen weniger, sie fragen ChatGPT, Perplexity, Claude. Wir richten deine Website so ein, dass diese Tools dich als Quelle zitieren — mit llms.txt, ai.txt, FAQ-Schema und sauberem JSON-LD.' },
  { num: '03', title: 'Conversion-Architektur ab Tag 1', body: 'Sticky-CTA, Mikro-Conversions, FAQ-Schema, Friction-Minimum bei Formularen, Loading-States, Erfolgs-Bestätigung mit klarem Next-Step. Alles, was bei Discount-Anbietern fehlt.' },
  { num: '04', title: 'Tracking sauber ab Go-Live', body: 'Microsoft Clarity (Heatmaps + Session-Recordings, DSGVO-konform mit Consent), Vercel Web Analytics, definierte Conversion-Events. Du siehst, was funktioniert.' },
  { num: '05', title: 'Du steuerst mit', body: 'Du bekommst Zugang zu Analytics ab Tag 1. Du verstehst die Daten. Du entscheidest, was geändert wird. Wir bauen technisch um — aber die Strategie steuerst du.' },
];

const performanceFacts = [
  { num: 'LCP < 1,5 s', title: 'Largest Contentful Paint', body: 'Bei langsameren Sites verlassen 40 % der Mobil-Nutzer:innen die Seite, bevor sie auch nur deinen Namen lesen.' },
  { num: 'SEO 100', title: 'Lighthouse Score', body: 'Saubere semantische Struktur, perfekte Meta-Tags, automatische Sitemap, JSON-LD pro Seite. Google rankt das. KI-Suchen lieben das.' },
  { num: 'CRO-Pflicht', title: 'Conversion-Elemente', body: 'Sticky-CTA auf Mobile, Mikro-Conversion-Ladder, FAQ-Schema für Rich-Results. Hier verlierst du Leads, wenn das fehlt.' },
];

const jsonLd = [
  breadcrumbSchema([
    { name: 'Startseite', url: '/' },
    { name: 'Branchen', url: '/branchen/kanzlei' },
    { name: 'Kanzlei', url: '/branchen/kanzlei' },
  ]),
  serviceSchema({
    name: 'Kanzlei-Website mit Lighthouse 100',
    description: 'Conversion-starke Websites für Kanzleien und Beratungen mit AEO-Setup und Tracking',
    url: '/branchen/kanzlei',
    price: 999,
    pages: '5–10',
    deliveryDays: 7,
  }),
];
---

<BaseLayout
  title={title}
  description={description}
  ogTitle="Kanzlei-Website · Lighthouse 100 · Festpreis"
  ogDescription="Performance-Beweise statt Stockfoto-Klischees. Für Steuerberater, Anwälte und Berater, die messen statt hoffen."
  ogImage="/og/branche-kanzlei.png"
  jsonLd={jsonLd}
>
  {/* HERO */}
  <Section variant="warm-white" size="xl">
    <p class="section-cap">Für Kanzleien, Steuerberatungen, Beratungen</p>
    <h1 class="mt-3 text-4xl sm:text-6xl font-bold text-ink-900 headline">
      Performance ist nicht Marketing. Performance ist Beweis.
    </h1>
    <p class="mt-5 max-w-3xl text-lg leading-relaxed text-ink-500">
      Wir bauen Websites für Kanzleien und Beratungen, die messen statt hoffen. Mit Lighthouse 100, AEO-Setup für KI-Suchen und Tracking ab Tag 1. Festpreis 999 €. 7 Tage Lieferung.
    </p>
    <div class="mt-9 flex flex-wrap gap-3">
      <Button href="/kontakt?branche=kanzlei" variant="primary" size="lg" arrow>In 30 Min gebrieft</Button>
      <Button href="https://pagespeed.web.dev/analysis/https-webhype-de-branchen-kanzlei" variant="secondary" size="lg">Performance live prüfen</Button>
    </div>
  </Section>

  {/* PAIN POINTS */}
  <Section variant="white" size="lg">
    <p class="section-cap">Kennst du das?</p>
    <h2 class="mt-3 text-3xl sm:text-5xl font-bold text-ink-900 headline">
      Drei Sätze, die jede:r Kanzlei-Inhaber:in unterschreibt.
    </h2>
    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {pains.map((p) => (
        <div class="rounded-2xl border border-ink-100 bg-warm-white p-7">
          <h3 class="text-lg font-bold text-ink-900 italic headline">{p.title}</h3>
          <p class="mt-4 text-[15px] leading-relaxed text-ink-500">{p.body}</p>
        </div>
      ))}
    </div>
  </Section>

  {/* WAS WIR ANDERS MACHEN */}
  <Section variant="warm-white" size="lg">
    <p class="section-cap">So bauen wir für Kanzleien</p>
    <h2 class="mt-3 text-3xl sm:text-5xl font-bold text-ink-900 headline">
      Fünf Dinge, bei denen wir andere übertreffen.
    </h2>
    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {differentiators.map((d) => (
        <div class="rounded-2xl border border-ink-100 bg-white p-7">
          <div class="font-mono text-xs font-bold uppercase tracking-wider text-spark">{d.num}</div>
          <h3 class="mt-3 text-xl font-bold text-ink-900 headline">{d.title}</h3>
          <p class="mt-3 text-[15px] leading-relaxed text-ink-500">{d.body}</p>
        </div>
      ))}
    </div>
  </Section>

  {/* PERFORMANCE FACTS */}
  <Section variant="ink" size="lg">
    <p class="section-cap" style="color:#00D4FF;">Warum Performance Geld wert ist</p>
    <h2 class="mt-3 text-3xl sm:text-5xl font-bold text-white headline">
      Diese Zahlen entscheiden, ob du den Lead bekommst.
    </h2>
    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {performanceFacts.map((p) => (
        <div class="rounded-2xl border border-white/10 bg-white/5 p-7 backdrop-blur-sm">
          <div class="font-mono text-2xl font-bold text-spark headline tnum">{p.num}</div>
          <h3 class="mt-3 text-xl font-bold text-white headline">{p.title}</h3>
          <p class="mt-3 text-[15px] leading-relaxed text-blue-100/80">{p.body}</p>
        </div>
      ))}
    </div>
  </Section>

  {/* FINAL CTA */}
  <Section variant="warm-white" size="xl">
    <h2 class="text-3xl sm:text-5xl md:text-6xl font-bold text-ink-900 headline">
      Bereit für eine Kanzlei-Website, die Daten liefert?
    </h2>
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-500">
      30 Min Briefing. Wir verstehen Mandanten-Conversion, weil wir selbst datenorientiert arbeiten.
    </p>
    <div class="mt-9 flex flex-wrap gap-3">
      <Button href="/kontakt?branche=kanzlei" variant="primary" size="lg" arrow>In 30 Min gebrieft</Button>
      <Button href="/pakete" variant="secondary" size="lg">Pakete ansehen</Button>
    </div>
  </Section>
</BaseLayout>
