---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';
import { breadcrumbSchema, serviceSchema } from '../../lib/schema';

const title = 'Website für Kanzleien & Beratungen – modern & schnell · webhype';
const description =
  'Moderne Website für deine Kanzlei oder Beratung. Bringt neue Mandanten, bei Google gut auffindbar, blitzschnell. In 7 Tagen fertig, fester Preis. Service aus Berlin.';

const pains = [
  { title: '„Meine Seite sieht aus wie alle anderen."', body: 'Aktenfoto, Bücherregal, „Vertrauen seit 1987". Wenn du gegen alteingesessene Kanzleien um den nächsten Mandanten kämpfst, fällst du so nicht auf.' },
  { title: '„Ich weiß nicht, ob meine Seite etwas bringt."', body: 'Du gibst Geld für deinen Auftritt aus, aber siehst nicht, ob daraus Anfragen werden — oder ob es nur eine teure Visitenkarte ist.' },
  { title: '„Ich will modern wirken, nicht verstaubt."', body: 'Deine Arbeit ist auf der Höhe der Zeit. Deine Website sollte das auch zeigen.' },
];

const points = [
  { num: '01', title: 'Modern statt verstaubt', body: 'Ein klarer, moderner Auftritt, der zu einer ernstzunehmenden Kanzlei passt — ohne Klischees, ohne Aktenfotos.' },
  { num: '02', title: 'Bringt neue Mandanten', body: 'Klare Wege zur Kontaktaufnahme, gut sichtbare Buttons, eine einfache Anfrage. Damit aus Besuchern echte Mandanten werden.' },
  { num: '03', title: 'Bei Google gut auffindbar', body: 'Wir richten deine Seite so ein, dass Mandanten dich finden, wenn sie nach deinem Fachgebiet suchen.' },
  { num: '04', title: 'Du siehst, was funktioniert', body: 'Auf Wunsch richten wir eine einfache, datenschutz-konforme Auswertung ein — damit du siehst, wie viele Leute deine Seite besuchen und anfragen.' },
];

const jsonLd = [
  breadcrumbSchema([
    { name: 'Startseite', url: '/' },
    { name: 'Branchen', url: '/branchen/kanzlei' },
    { name: 'Kanzlei', url: '/branchen/kanzlei' },
  ]),
  serviceSchema({ name: 'Website für Kanzleien & Beratungen', description: 'Moderne, schnelle Websites, die Mandanten bringen, in 7 Tagen fertig', url: '/branchen/kanzlei', price: 999, pages: '5–10', deliveryDays: 7 }),
];
---

<BaseLayout title={title} description={description} ogTitle="Kanzlei-Website · modern · 7 Tage" ogDescription="Bringt Mandanten, bei Google auffindbar, blitzschnell. Service aus Berlin." ogImage="/og/branche-kanzlei.png" jsonLd={jsonLd}>
  {/* HERO */}
  <Section variant="warm-white" size="xl">
    <div class="max-w-3xl" data-reveal>
      <p class="eyebrow">Für Kanzleien & Beratungen</p>
      <h1 class="display-xl mt-3 text-ink-900">Modern auftreten. Mandanten gewinnen.</h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-500">
        Für Anwälte, Steuerberater und Berater, die online genauso überzeugen wollen wie im Gespräch. Modern, schnell, bei Google gut auffindbar. In 7 Tagen fertig, fester Preis.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <Button href="/kontakt?branche=kanzlei" variant="primary" size="lg" arrow>Gespräch anfragen</Button>
        <Button href="/pakete" variant="secondary" size="lg">Preise ansehen</Button>
      </div>
    </div>
  </Section>

  {/* PAINS */}
  <Section variant="white" size="lg">
    <div data-reveal><p class="eyebrow">Kennst du das?</p><h2 class="display-lg mt-3 text-ink-900">Drei Sätze, die wir oft hören.</h2></div>
    <div class="mt-12 grid gap-5 md:grid-cols-3" data-reveal-group>
      {pains.map((p) => (
        <div class="rounded-2xl border border-ink-100 bg-warm-white p-7">
          <h3 class="text-lg font-bold text-ink-900 italic headline">{p.title}</h3>
          <p class="mt-4 text-[15px] leading-relaxed text-ink-500">{p.body}</p>
        </div>
      ))}
    </div>
  </Section>

  {/* POINTS */}
  <Section variant="warm-white" size="lg">
    <div data-reveal><p class="eyebrow">So bauen wir für Kanzleien</p><h2 class="display-lg mt-3 text-ink-900">Vier Dinge, die den Unterschied machen.</h2></div>
    <div class="mt-12 grid gap-5 md:grid-cols-2" data-reveal-group>
      {points.map((d) => (
        <div class="rounded-2xl border border-ink-100 bg-white p-7">
          <div class="font-mono text-xs font-bold uppercase tracking-wider text-blue-500">{d.num}</div>
          <h3 class="mt-3 text-xl font-bold text-ink-900 headline">{d.title}</h3>
          <p class="mt-3 text-[15px] leading-relaxed text-ink-500">{d.body}</p>
        </div>
      ))}
    </div>
  </Section>

  {/* FINAL CTA */}
  <Section variant="ink" size="xl">
    <div data-reveal>
      <h2 class="display-lg text-white">Bereit für eine Kanzlei-Website, die Mandanten bringt?</h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-blue-100">Ein kurzes Gespräch von max. 30 Minuten.</p>
      <div class="mt-9 flex flex-wrap gap-3">
        <Button href="/kontakt?branche=kanzlei" variant="primary" size="lg" arrow>Gespräch anfragen</Button>
        <Button href="/preis-finden" variant="inverted" size="lg">Paket finden</Button>
      </div>
    </div>
  </Section>
</BaseLayout>
