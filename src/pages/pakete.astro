---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import PricingTable from '../components/PricingTable.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import { faqSchema, serviceSchema, breadcrumbSchema } from '../lib/schema';

const title = 'Preise: 499 € oder 999 € – fester Preis · webhype';
const description =
  'Zwei Größen, zwei Wege: mit Rundum-Service (kleiner Monatsbeitrag) oder einmalig zur Übergabe. Fester Preis, in 7 Tagen fertig. Service aus Berlin.';

const compareRows = [
  { label: 'Seiten', starter: 'bis zu 5', business: 'bis zu 10' },
  { label: 'Fertig in', starter: '7 Tagen', business: '7 Tagen' },
  { label: 'Kontaktformular & Telefon-Knopf', starter: true, business: true },
  { label: 'Datenschutz & Impressum', starter: true, business: true },
  { label: 'Blitzschnell & fürs Handy', starter: true, business: true },
  { label: 'Bei Google auffindbar', starter: true, business: true },
  { label: 'Eigene Seiten für deine Leistungen', starter: false, business: true },
  { label: 'Texte & Bilder selbst ändern', starter: true, business: true },
  { label: 'Eine Korrekturrunde inklusive', starter: true, business: true },
];

const faqItems = [
  {
    question: 'Was ist der Unterschied zwischen den zwei Wegen?',
    answer: 'Beim Rundum-Service kümmern wir uns dauerhaft um alles: Deine Seite ist immer online, wir prüfen sie täglich, halten sie sicher — dafür ein kleiner Monatsbeitrag (19 € oder 29 €). Bei der Übergabe bekommst du die fertige Website einmalig und kümmerst dich danach selbst um Technik und Hosting — kein Monatsbeitrag, dafür ein höherer Einmalpreis.',
  },
  {
    question: 'Was passiert, wenn ich später mehr Seiten brauche?',
    answer: 'Kein Problem. Wir besprechen, was du brauchst, und machen dir vorher einen festen Preis. Wenn dein Vorhaben sehr groß wird (Online-Shop, viele Sprachen), sind wir ehrlich und sagen dir, dass eine größere Agentur besser passt.',
  },
  {
    question: 'Bin ich an euch gebunden?',
    answer: 'Nein. Der Monatsbeitrag ist monatlich kündbar, und deine Domain gehört immer dir. Du kannst jederzeit wechseln — die meisten bleiben einfach, weil alles läuft.',
  },
];

const jsonLd = [
  breadcrumbSchema([
    { name: 'Startseite', url: '/' },
    { name: 'Preise', url: '/pakete' },
  ]),
  serviceSchema({ name: 'webhype Starter', description: 'Website mit bis zu 5 Seiten, in 7 Tagen fertig', url: '/pakete', price: 499, pages: '5', deliveryDays: 7 }),
  serviceSchema({ name: 'webhype Business', description: 'Website mit bis zu 10 Seiten, in 7 Tagen fertig', url: '/pakete', price: 999, pages: '10', deliveryDays: 7 }),
  faqSchema(faqItems),
];
---

<BaseLayout
  title={title}
  description={description}
  ogTitle="Fester Preis. Du weißt vorher, was es kostet."
  ogDescription="Mit Rundum-Service oder einmalig zur Übergabe. In 7 Tagen fertig. Service aus Berlin."
  ogImage="/og/pakete.png"
  jsonLd={jsonLd}
>
  {/* HERO */}
  <Section variant="warm-white" size="xl">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <p class="eyebrow justify-center">Einfache Preise</p>
      <h1 class="display-xl mt-3 text-ink-900">Du weißt vorher, was es kostet.</h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-500">
        Such dir aus, wie du es haben willst: Wir kümmern uns dauerhaft um alles (kleiner Monatsbeitrag) — oder du bekommst die Website einmalig und machst dann selbst weiter. Fester Preis, ohne Überraschung.
      </p>
    </div>
  </Section>

  {/* PRICING TABLE (4 models via toggle) */}
  <Section variant="white" size="lg">
    <PricingTable />

    <div class="mt-10 rounded-2xl bg-ink-50 border border-ink-100 p-6 sm:p-7 text-center max-w-3xl mx-auto" data-reveal>
      <h3 class="text-lg font-bold text-ink-900 headline">Du weißt nicht, was du brauchst?</h3>
      <p class="mt-2 text-[15px] text-ink-500">Beantworte ein paar einfache Fragen — wir schlagen dir das passende Paket vor.</p>
      <div class="mt-5">
        <Button href="/preis-finden" variant="primary" arrow>In 2 Minuten dein Paket finden</Button>
      </div>
    </div>
  </Section>

  {/* VERGLEICH */}
  <Section variant="warm-white" size="lg">
    <div data-reveal>
      <p class="eyebrow">Im Überblick</p>
      <h2 class="display-lg mt-3 text-ink-900">Was in welchem Paket steckt.</h2>
    </div>

    <div class="mt-10 overflow-x-auto rounded-2xl border border-ink-100 bg-white" data-reveal>
      <table class="w-full text-left text-[15px]">
        <thead class="bg-ink-50">
          <tr>
            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-ink-500">&nbsp;</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-ink-500">Starter</th>
            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-blue-500">Business</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-ink-100">
          {compareRows.map((row) => (
            <tr>
              <td class="px-6 py-3.5 text-ink-700">{row.label}</td>
              <td class="px-6 py-3.5">{row.starter === true ? (<span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-success/15 text-success" aria-label="ja"><svg width="14" height="14" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>) : row.starter === false ? (<span class="text-ink-300" aria-label="nein">—</span>) : (<span class="font-mono text-sm text-ink-900">{row.starter}</span>)}</td>
              <td class="px-6 py-3.5">{row.business === true ? (<span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-success/15 text-success" aria-label="ja"><svg width="14" height="14" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>) : row.business === false ? (<span class="text-ink-300" aria-label="nein">—</span>) : (<span class="font-mono text-sm text-ink-900">{row.business}</span>)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  {/* WAS WIR NICHT MACHEN */}
  <Section variant="white" size="lg">
    <div data-reveal>
      <p class="eyebrow">Ehrlich gesagt</p>
      <h2 class="display-lg mt-3 text-ink-900">Was wir nicht machen.</h2>
      <p class="mt-5 max-w-3xl text-lg leading-relaxed text-ink-500">
        Wir bauen schnelle, klare Websites für kleine und mittlere Betriebe. Wenn du etwas davon brauchst, sind wir nicht die Richtigen — und sagen dir das vorher, nicht nachdem du gezahlt hast.
      </p>
    </div>
    <div class="mt-8 grid gap-3 sm:grid-cols-2 max-w-3xl" data-reveal-group>
      {[
        'Online-Shop mit Warenkorb',
        'Website in mehreren Sprachen',
        'Großer Mitglieder-Bereich mit Login',
        'Sehr aufwendige Animationen',
      ].map((item) => (
        <div class="flex items-center gap-3 rounded-xl border border-dashed border-ink-200 bg-warm-white px-4 py-3 text-[15px] text-ink-700">
          <span class="text-error font-bold">✗</span> {item}
        </div>
      ))}
    </div>
  </Section>

  {/* FAQ */}
  <section class="bg-ink-50 py-16 sm:py-24 border-t border-ink-100" id="faq">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div data-reveal>
        <p class="eyebrow">Häufige Fragen</p>
        <h2 class="display-lg mt-3 text-ink-900">Die kurzen Antworten.</h2>
      </div>
      <div class="mt-10 max-w-3xl" data-reveal>
        <FaqAccordion items={faqItems} />
      </div>
    </div>
  </section>

  {/* FINAL CTA */}
  <Section variant="ink" size="xl">
    <div data-reveal>
      <p class="eyebrow is-spark is-light">Lass uns reden</p>
      <h2 class="display-lg mt-3 text-white">Welches Paket passt zu dir?</h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-blue-100">Ein kurzes Gespräch von max. 30 Minuten. Wir empfehlen dir, was sinnvoll ist — ehrlich, auch wenn es das kleinere Paket ist.</p>
      <div class="mt-9 flex flex-wrap gap-3">
        <Button href="/kontakt" variant="spark" size="lg" arrow>Termin vereinbaren</Button>
        <Button href="/preis-finden" variant="inverted" size="lg">Paket-Finder starten</Button>
      </div>
    </div>
  </Section>
</BaseLayout>
