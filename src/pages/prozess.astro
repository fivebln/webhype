---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import { faqSchema, howToSchema, breadcrumbSchema } from '../lib/schema';

const title = 'So läuft es ab: kurzes Gespräch, 7 Tage später fertig · webhype';
const description =
  'Fünf einfache Schritte: kurze Anfrage, ein kurzes Gespräch, wir bauen, du schaust drüber, deine Seite geht online. In einer Woche fertig — du musst dich um nichts kümmern.';

const steps = [
  { num: '01', day: 'Tag 0 · 2 Minuten', title: 'Du meldest dich', headline: 'Eine kurze Anfrage genügt.', text: 'Du schickst uns über das Formular ein paar Eckdaten zu deinem Betrieb — was du machst, für wen, welches Paket dich interessiert. Alles Weitere klären wir gemeinsam im Gespräch, ganz ohne Fragebogen-Marathon.' },
  { num: '02', day: 'Tag 1 · max. 30 Minuten', title: 'Ein kurzes Gespräch', headline: 'Wir reden einmal — dann übernehmen wir.', text: 'Wir telefonieren oder machen einen kurzen Videocall. Du erzählst von deinem Betrieb, wir klären alle Fragen und das passende Paket. Nach spätestens 30 Minuten ist alles besprochen — und die eine Woche beginnt.' },
  { num: '03', day: 'Tag 1–6', title: 'Wir bauen deine Website', headline: 'Du machst dein Geschäft, wir machen die Website.', text: 'Sechs Tage lang bauen wir — ohne weitere Termine, ohne dass du etwas tun musst.' },
  { num: '04', day: 'Tag 7', title: 'Du schaust drüber', headline: 'Deine fertige Website zum Anschauen.', text: 'Du bekommst deine Website zu sehen. Etwas gefällt dir nicht oder fehlt? Sag Bescheid — eine Korrekturrunde ist im Preis dabei.' },
  { num: '05', day: 'Tag 8', title: 'Deine Seite geht online', headline: 'Wir kümmern uns um die Technik.', text: 'Wir schalten deine Website live und kümmern uns um alles Technische. Du musst nichts einrichten, nichts installieren — es läuft einfach.' },
];

const faqItems = [
  { question: 'Muss ich Texte und Bilder selbst schreiben?', answer: 'Nein. Stichpunkte reichen — die fertigen Texte schreiben wir. Wenn du eigene Fotos hast (von dir, deinem Team, deinem Betrieb), nutzen wir die gern. Wenn nicht, suchen wir passende, ordentlich lizenzierte Bilder.' },
  { question: 'Was, wenn ich nach dem Gespräch noch etwas vergessen habe?', answer: 'Kein Problem. Bis Tag 2 kannst du noch Sachen nachreichen. Kleine Ergänzungen gehen auch später. Größere Nachträge verschieben den Termin entsprechend — wir sagen dir das ehrlich.' },
  { question: 'Haltet ihr die 7 Tage wirklich ein?', answer: 'In über 95 % der Fälle ja — verbindlich ab unserem Gespräch. Wichtig ist nur, dass du uns deine Unterlagen rechtzeitig gibst. Sollte einmal etwas dazwischenkommen, melden wir uns sofort und finden eine Lösung.' },
];

const jsonLd = [
  breadcrumbSchema([
    { name: 'Startseite', url: '/' },
    { name: 'Ablauf', url: '/prozess' },
  ]),
  howToSchema({ name: 'So entsteht deine Website in 7 Tagen', description: 'Fünf einfache Schritte von der Anfrage bis online', steps: steps.map((s) => ({ name: s.title, text: s.text })) }),
  faqSchema(faqItems),
];
---

<BaseLayout
  title={title}
  description={description}
  ogTitle="Kurzes Gespräch. 7 Tage später fertig."
  ogDescription="Fünf einfache Schritte. Du musst dich um nichts kümmern."
  ogImage="/og/prozess.png"
  jsonLd={jsonLd}
>
  {/* HERO */}
  <Section variant="warm-white" size="xl">
    <div class="max-w-3xl" data-reveal>
      <p class="eyebrow">So läuft es ab</p>
      <h1 class="display-xl mt-3 text-ink-900">Von der Anfrage zur fertigen Website — in einer Woche.</h1>
      <p class="mt-5 text-lg leading-relaxed text-ink-500">
        Fünf einfache Schritte. Dein ganzer Aufwand: eine kurze Anfrage und ein kurzes Gespräch. Den Rest übernehmen wir.
      </p>
    </div>
  </Section>

  {/* STEPS */}
  <Section variant="white" size="lg">
    <ol class="space-y-12">
      {steps.map((s) => (
        <li class="grid gap-8 md:grid-cols-[200px_1fr] md:gap-12" data-reveal>
          <div class="md:sticky md:top-24 md:self-start">
            <span class="font-mono text-5xl font-bold text-blue-500 headline tnum">{s.num}</span>
            <p class="mt-2 font-mono text-xs uppercase tracking-wider text-ink-300">{s.day}</p>
          </div>
          <div class="border-l border-ink-100 pl-8">
            <h2 class="text-2xl sm:text-3xl font-bold text-ink-900 headline">{s.title}</h2>
            <p class="mt-3 text-lg font-medium text-ink-700">{s.headline}</p>
            <p class="mt-4 text-[15px] leading-relaxed text-ink-500">{s.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </Section>

  {/* WAS DU BRAUCHST */}
  <Section variant="warm-white" size="lg">
    <div data-reveal>
      <p class="eyebrow">Was wir von dir brauchen</p>
      <h2 class="display-lg mt-3 text-ink-900">Höchstens eine Stunde Aufwand. Versprochen.</h2>
    </div>
    <div class="mt-12 grid gap-5 md:grid-cols-2" data-reveal-group>
      <div class="rounded-2xl border-2 border-blue-200 bg-white p-7">
        <div class="text-xs font-bold uppercase tracking-wider text-blue-500">Das brauchen wir</div>
        <ul class="mt-4 space-y-2 text-[15px] text-ink-900">
          <li class="flex gap-2"><span class="text-success">✓</span> Dein Logo (falls vorhanden)</li>
          <li class="flex gap-2"><span class="text-success">✓</span> Ein paar Stichpunkte zu deinen Leistungen</li>
          <li class="flex gap-2"><span class="text-success">✓</span> Adresse, Telefon, E-Mail</li>
          <li class="flex gap-2"><span class="text-success">✓</span> Angaben fürs Impressum</li>
        </ul>
      </div>
      <div class="rounded-2xl border border-dashed border-ink-200 bg-white p-7">
        <div class="text-xs font-bold uppercase tracking-wider text-ink-400">Das brauchst du NICHT</div>
        <ul class="mt-4 space-y-2 text-[15px] text-ink-500">
          <li>Keine fertigen Texte — Stichpunkte reichen</li>
          <li>Kein Technik-Wissen</li>
          <li>Keine Skizzen oder Entwürfe</li>
          <li>Keine teuren Fotos</li>
        </ul>
      </div>
    </div>
  </Section>

  {/* FAQ */}
  <section class="bg-ink-50 py-16 sm:py-24 border-t border-ink-100" id="faq">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div data-reveal>
        <p class="eyebrow">Häufige Fragen</p>
        <h2 class="display-lg mt-3 text-ink-900">Die häufigsten Bedenken.</h2>
      </div>
      <div class="mt-10 max-w-3xl" data-reveal>
        <FaqAccordion items={faqItems} />
      </div>
    </div>
  </section>

  {/* FINAL CTA */}
  <Section variant="ink" size="xl">
    <div data-reveal>
      <p class="eyebrow is-spark is-light">Klingt machbar?</p>
      <h2 class="display-lg mt-3 text-white">Dann lass uns starten.</h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-blue-100">Ein kurzes Gespräch von max. 30 Minuten. Termine meist innerhalb von zwei Tagen.</p>
      <div class="mt-9 flex flex-wrap gap-3">
        <Button href="/kontakt" variant="primary" size="lg" arrow>Termin vereinbaren</Button>
        <Button href="/pakete" variant="inverted" size="lg">Preise ansehen</Button>
      </div>
    </div>
  </Section>
</BaseLayout>
