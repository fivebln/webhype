---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';
import { getBlogPosts } from '../../lib/marketingBlog';
import { breadcrumbSchema } from '../../lib/schema';

export const prerender = false;

const posts = await getBlogPosts(30);
const featured = posts[0];
const rest = posts.slice(1);

const crumb = breadcrumbSchema([
  { name: 'Start', url: '/' },
  { name: 'Magazin', url: '/blog' },
]);

const fmt = (d?: string) =>
  d ? new Date(d).toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' }) : '';
const meta = (p: { veroeffentlichtAm?: string; lesezeitMin?: number }) =>
  [fmt(p.veroeffentlichtAm), p.lesezeitMin ? `${p.lesezeitMin} Min. Lesezeit` : '']
    .filter(Boolean)
    .join(' · ');
---

<BaseLayout
  title="Magazin: ehrliche Antworten rund um deine Website · webhype"
  description="Klartext zu Kosten, Baukasten vs. Agentur, Sichtbarkeit bei Google und den Rechtspflichten einer Website, für Selbstständige und kleine Unternehmen. Aus der Praxis von webhype."
  jsonLd={crumb}
>
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" title="webhype-Magazin" href="/blog/rss.xml" />
  </Fragment>

  <Section variant="white" size="lg">
    <div class="max-w-3xl" data-reveal>
      <p class="section-cap mb-3">Magazin</p>
      <h1 class="display-lg text-ink-900">Ehrliche Antworten rund um deine Website.</h1>
      <p class="mt-6 max-w-2xl text-body-lg text-ink-500">
        Kein Fachchinesisch, keine Verkaufsmasche. Wir schreiben über das, was Selbstständige und kleine
        Unternehmen wirklich fragen: was eine Website kostet, warum ein Baukasten selten reicht und wie du
        über Google gefunden wirst.
      </p>
    </div>
  </Section>

  {posts.length === 0 ? (
    <Section variant="warm-white" size="lg">
      <div class="mx-auto max-w-xl rounded-2xl border border-ink-100 bg-white p-8 text-center shadow-sm">
        <h2 class="text-h3 text-ink-900">Die ersten Beiträge sind in Arbeit.</h2>
        <p class="mt-3 text-body text-ink-500">
          Wir schreiben gerade an den ersten Artikeln. Du hast jetzt schon eine Frage zu deiner Website?
          Dann sprich uns direkt an. Im ersten Gespräch klären wir sie kostenlos.
        </p>
        <Button href="/kontakt" class="mt-6" arrow>Gespräch anfragen</Button>
      </div>
    </Section>
  ) : (
    <Section variant="warm-white" size="lg">
      {/* Aufmacher — asymmetrisch (Bild + Text), bricht das gleichförmige Karten-Raster */}
      <a
        href={`/blog/${featured.slug}`}
        class="group grid overflow-hidden rounded-2xl border border-ink-100 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md md:grid-cols-[1.15fr_1fr]"
        data-reveal
      >
        <div class="relative aspect-[16/10] overflow-hidden bg-blue-50 md:aspect-auto">
          {featured.titelbild ? (
            <img
              src={featured.titelbild}
              alt={featured.titel}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
              loading="eager"
              decoding="async"
            />
          ) : (
            <div class="hero-gradient h-full w-full"></div>
          )}
        </div>
        <div class="flex flex-col justify-center p-7 sm:p-9">
          <div class="mb-3 flex flex-wrap items-center gap-3 text-body-sm">
            {featured.kategorie && (
              <span class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-600">
                {featured.kategorie}
              </span>
            )}
            <span class="text-ink-300">{meta(featured)}</span>
          </div>
          <h2 class="font-headline text-h2 leading-tight text-ink-900 group-hover:text-blue-600">
            {featured.titel}
          </h2>
          <p class="mt-3 text-body text-ink-500">{featured.teaser}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-blue-500">
            Weiterlesen <span aria-hidden="true">→</span>
          </span>
        </div>
      </a>

      {rest.length > 0 && (
        <div class="mt-8 grid gap-6 sm:grid-cols-2" data-reveal-group>
          {rest.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex h-full flex-col overflow-hidden rounded-2xl border border-ink-100 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md"
            >
              <div class="aspect-[16/9] overflow-hidden bg-blue-50">
                {post.titelbild ? (
                  <img
                    src={post.titelbild}
                    alt={post.titel}
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="hero-gradient h-full w-full"></div>
                )}
              </div>
              <div class="flex flex-1 flex-col p-6">
                <div class="mb-2.5 flex flex-wrap items-center gap-2.5 text-body-sm">
                  {post.kategorie && (
                    <span class="inline-flex rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-semibold text-blue-600">
                      {post.kategorie}
                    </span>
                  )}
                  <span class="text-ink-300">{meta(post)}</span>
                </div>
                <h3 class="font-headline text-h4 leading-snug text-ink-900 group-hover:text-blue-600">
                  {post.titel}
                </h3>
                <p class="mt-2 line-clamp-3 text-body-sm text-ink-500">{post.teaser}</p>
                <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-blue-500">
                  Weiterlesen <span aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </Section>
  )}

  <Section variant="ink" size="lg">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <h2 class="font-headline text-h2 text-white">Reden wir über deine Website.</h2>
      <p class="mt-4 text-body-lg text-blue-100">
        In einem 30-minütigen Gespräch klären wir, was du brauchst, unverbindlich und ohne Fachchinesisch.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/kontakt" variant="primary" size="lg" arrow>Gespräch anfragen</Button>
        <Button href="/pakete" variant="inverted" size="lg">Preise ansehen</Button>
      </div>
    </div>
  </Section>
</BaseLayout>
