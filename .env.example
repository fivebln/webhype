# Copy to .env.local and fill in. Never commit .env.local.

# Public site URL (used for canonical + sitemap)
SITE_URL=http://localhost:4321

# Resend (mail delivery) — required for /api/contact in production
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=webhype <no-reply@web-hype.de>

# Where internal notifications go
CONTACT_INBOX=hallo@web-hype.de
